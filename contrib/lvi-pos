#!/bin/sh
# lvi-pos [-w auto|WID] save | restore [-n]
#
# Remember where you were in each file across sessions -- vi/vim's `` `" `` mark,
# restored from viminfo -- but as a plain-text store and a couple of `:on` hooks
# instead of an in-editor database. Two subcommands, wired to editor events in
# your rc (see lvirc.sample.vim):
#
#   save     record the current file's cursor position to the store. Bind to the
#            moments a position is worth keeping: `on change` (after an edit
#            settles), `on write`, `on bufleave` (leaving a buffer).
#   restore  look the current file up in the store and set the `` `" `` mark at the
#            spot WITHOUT moving the cursor -- you open the file fresh (at the top)
#            but `` `" `` carries you to where you left off when you ask for it.
#            This is the default because it moves nothing, so it composes safely on
#            any event -- it can't fight a list jump (lvi-gitchanges/-search) or
#            another cursor mover firing on the same buffer switch. With -j
#            (--jump) it ALSO moves the cursor there, to resume automatically --
#            the surprising behavior, which you opt into. Bind restore to `on
#            ready` (the launch file) and/or `on bufenter` (files opened later with
#            :e); keep -j to `ready`, since a jump on `bufenter` clobbers cross-file
#            list navigation (see THE CONFLICT below).
#
# THE STORE is a tab-delimited text file, newest entry last, one line per file:
#     /abs/path/to/file<TAB>LINE<TAB>COL
# grep-able, hand-editable, and capped like viminfo's `'N` (LVI_POS_MAX). It
# lives under $XDG_STATE_HOME (machine-written state, not config); override the
# whole path with LVI_POS_FILE. Paths are absolutised against $PWD (the hook
# inherits the editor's launch directory) so the same file keys the same entry no
# matter where lvi was started.
#
# RESTORE IS GUARDED so it only acts on a FRESH read (the buffer sitting at line
# 1): a freshly read file starts there; a buffer you're revisiting already has
# lvi's own in-memory per-buffer cursor where you left it this session, so restore
# stands aside rather than re-marking (or, with -j, yanking) it. All edits go over
# the socket, which never arms `change`/`bufenter`, so save and restore can't loop.
#
# The in-session last-CHANGE mark (`` `. ``) is NOT this tool's job: the `on change`
# hook can fire while you're still in insert mode (a typing pause), so the core
# stamps `` `. `` itself as you edit; this tool only sets the cross-session `` `" ``.
# It does so with `:mark " LINE COL`, the ex-side setter that drops a mark at an
# address WITHOUT moving the cursor -- which is exactly what makes a mark-only
# restore composable (see THE CONFLICT).
#
# THE CONFLICT (why -j belongs on `ready`, not `bufenter`): a cursor-moving list
# tool (lvi-gitchanges, lvi-search) steps to a match in another file by opening it
# (:e) and jumping. That :e fires `bufenter`, and a restore bound there with -j
# ALSO moves the cursor -- landing AFTER the list's jump and stealing it (you end
# up at your last-known line, or at the top, instead of the match). The default
# mark-only restore has no such fight: it never moves the cursor, so it's safe on
# `bufenter`. Reserve -j for `ready`, where nothing is stepping a list.
#
# Bind it (all touch no tty -> a detached spawn is implicit for `on` hooks):
#     on change   lvi-pos save
#     on write    lvi-pos save
#     on bufleave lvi-pos save
#     on bufenter lvi-pos restore       " set `" on every file you open (no move)
#     on ready    lvi-pos restore       " ...same for the launch file
# Add -j to auto-jump to where you left off -- safe on `ready`, NOT on `bufenter`:
#     on ready    lvi-pos restore -j
#
# Config: LVI (client, default `lvi`), LVI_POS_FILE (store path, default
# $XDG_STATE_HOME/lvi/positions), LVI_POS_MAX (entries to keep, default 1000).
# Run from inside lvi ($LVI_WID/$LVI_FILE/$LVI_LINE exported by the hook); from
# elsewhere pass -w and cd to the tree so relative paths resolve alike.

# -h/--help: print this script's header comment (its full reference), then exit.
case ${1:-} in -h|--help) exec awk 'NR==1&&/^#!/{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0" ;; esac
LVI=${LVI:-lvi}
store=${LVI_POS_FILE:-${XDG_STATE_HOME:-$HOME/.local/state}/lvi/positions}
maxn=${LVI_POS_MAX:-1000}

want_wid=; [ "$1" = "-w" ] && { want_wid=$2; shift 2; }
sub=${1:-}; [ -n "$sub" ] && shift
# restore [-j]: by DEFAULT set the `" mark WITHOUT moving the cursor -- the safe,
# composable choice, since a mark-only restore can't fight a list jump (or any
# other cursor mover) on the same event. -j/--jump ALSO moves the cursor to the
# saved spot ("resume here") -- the surprising bit you opt into, and best bound to
# `ready` (startup) rather than `bufenter`, where it would clobber list navigation
# across files. -n/--no-jump is the old spelling of today's default, accepted as a
# no-op so existing rc lines keep working.
jump=
case "$1" in
  -j|--jump)    jump=1; shift ;;
  -n|--no-jump) shift ;;                    # now the default; kept as a compat no-op
esac
target=${want_wid:-${LVI_WID:-auto}}
send() { $LVI -w "$target" --detach -- "$@"; }

# Validate the subcommand before touching the socket, so a typo reports usage
# rather than silently no-op'ing on the (later) empty-file guard.
case "$sub" in
  save|restore) ;;
  *) echo "usage: lvi-pos [-w auto|WID] save | restore [-n]" >&2; exit 2 ;;
esac

# The buffer's file: from the env when spawned by a hook, else ask over the
# socket. No name -> nothing to key on, so quietly do nothing (a hook must not
# be noisy). Absolutise so the key is stable across launch directories.
# `-` not `:-`: a hook always exports LVI_FILE (empty for an unnamed buffer, which
# we then skip); only a manual run from another terminal leaves it unset -> ask.
file=${LVI_FILE-$($LVI -w "$target" -- f | sed -n 's/^"\(.*\)" [0-9]* lines$/\1/p')}
case "$file" in ""|"[No File]"|"[No Name]") exit 0 ;; esac
case "$file" in /*) ;; *) file="$PWD/$file" ;; esac

# Skip volatile files, the way viminfo skips gitcommit/gitrebase and temp edits:
# a remembered position there is meaningless (a fresh COMMIT_EDITMSG every time).
case "${file##*/}" in COMMIT_EDITMSG|MERGE_MSG|TAG_EDITMSG|git-rebase-todo|*.tmp) exit 0 ;; esac
case "$file" in /tmp/*) exit 0 ;; esac

case "$sub" in
save)
  line=${LVI_LINE:-1}; col=${LVI_COL:-1}
  case "$line" in ''|*[!0-9]*) line=1 ;; esac
  case "$col"  in ''|*[!0-9]*) col=1  ;; esac
  mkdir -p "$(dirname "$store")" 2>/dev/null || exit 0
  tmp=$(mktemp "$store.XXXXXX") || exit 0
  trap 'rm -f "$tmp"' EXIT INT TERM
  # Drop any old entry for this file, append the fresh one, keep the newest maxn.
  # awk keys on the whole first field, so a path with spaces is fine (only the
  # tab separates columns). mv makes the replacement atomic.
  { awk -F'\t' -v f="$file" '$1 != f' "$store" 2>/dev/null
    printf '%s\t%s\t%s\n' "$file" "$line" "$col"
  } | tail -n "$maxn" >"$tmp" && mv "$tmp" "$store"
  ;;
restore)
  # Only act on a buffer at line 1 (a fresh read); a revisited buffer already
  # carries lvi's live cursor -- leave it be (see header).
  case "${LVI_LINE:-1}" in 1|"") ;; *) exit 0 ;; esac
  line=$(awk -F'\t' -v f="$file" '$1 == f { print $2 }' "$store" 2>/dev/null)
  case "$line" in ''|*[!0-9]*|0|1) exit 0 ;; esac      # nothing worth jumping to
  col=$(awk -F'\t' -v f="$file" '$1 == f { print $3 }' "$store" 2>/dev/null)
  case "$col" in ''|*[!0-9]*|0) col=1 ;; esac          # older/short entries -> column 1
  # Drop the `" mark at the exact spot -- line AND byte column, like Vim's `" mark.
  # `:mark " LINE COL` sets it byte-exactly WITHOUT moving the cursor, so the
  # (default) mark-only restore never touches the cursor -- it can't fight a list
  # jump or any other bufenter cursor mover. :mark clamps a stale line/col (the
  # file shrank since we saved) into the buffer, the same tolerance as viminfo.
  #
  # With -j we ALSO move the cursor there to resume: :pos does the byte-exact move
  # (a plain ${line}G lands on the first non-blank, and no normal-mode motion
  # reaches a raw byte column). This is the surprising bit; keep it off `bufenter`.
  send "mark \" $line $col"
  [ -n "$jump" ] && send "pos $line $col"
  ;;
esac
