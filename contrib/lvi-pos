#!/bin/sh
# lvi-pos [-w auto|WID] save | restore [-j] -- remember where you were in each
# file across sessions: vi/vim's `` `" `` mark, restored from viminfo, but as a
# plain-text store and a couple of `:on` hooks instead of an in-editor database.
# Two subcommands, wired to editor events in your rc (see lvirc.sample.vim).
#
# SYNOPSIS
#   lvi-pos save         record the current file's cursor position to the store
#   lvi-pos restore      set the `` `" `` mark at the saved spot WITHOUT moving the
#                        cursor: you open the file at the top, and `` `" `` carries
#                        you back when you ask for it. The default -- it moves
#                        nothing, so it composes on any event and can't fight a
#                        list jump (lvi-gitchanges/-search) or another cursor mover.
#   lvi-pos restore -j   ...and also move the cursor there, to resume
#                        automatically. Safe on `ready`, NOT on `bufenter` (see
#                        THE CONFLICT). -j is --jump.
#
# BIND IT (all touch no tty -> `on` hooks spawn them detached):
#     on change   lvi-pos save          " after an edit settles
#     on write    lvi-pos save
#     on bufleave lvi-pos save           " leaving a buffer
#     on exit     lvi-pos save           " the last buffer's spot at :q
#     on bufenter lvi-pos restore        " set `" on every file you open (no move)
#     on ready    lvi-pos restore        " ...same for the launch file
#     on ready    lvi-pos restore -j     " auto-jump; ONLY on ready, never bufenter
#
# THE STORE is a tab-delimited text file, newest entry last, one line per file:
#     /abs/path/to/file<TAB>LINE<TAB>COL
# grep-able, hand-editable, and capped like viminfo's `'N` (LVI_POS_MAX). It
# lives under $XDG_STATE_HOME (machine-written state, not config); LVI_POS_FILE
# overrides the whole path. Paths are absolutised against $PWD (the hook inherits
# lvi's launch directory) so the same file keys the same entry no matter where
# lvi was started.
#
# GUARDED: restore only acts on a FRESH read (the buffer at line 1). A buffer
# you're revisiting already carries lvi's own in-memory cursor where you left it
# this session, so restore stands aside rather than re-marking (or, with -j,
# yanking) it. No loops: save touches no socket, and restore's commands (:mark,
# :pos) edit nothing and switch no buffer, so neither can retrigger the hooks
# that fire them. (The in-session last-change mark `` `. `` is the core's job, not
# this tool's -- restore only sets the cross-session `` `" ``.)
#
# THE CONFLICT (why -j belongs on `ready`, not `bufenter`): a cursor-moving list
# tool (lvi-gitchanges, lvi-search) steps to a match in another file by opening
# it (:e) and jumping. That :e fires `bufenter`, and a -j restore bound there
# ALSO moves the cursor -- landing AFTER the list's jump and stealing it. The
# default mark-only restore never moves the cursor, so it's safe on `bufenter`.
# Reserve -j for `ready`, where nothing is stepping a list.
#
# Config: LVI (client, default `lvi`), LVI_POS_FILE (store path, default
# $XDG_STATE_HOME/lvi/positions), LVI_POS_MAX (entries to keep, default 1000).
# Run from inside lvi ($LVI_WID/$LVI_FILE/$LVI_LINE exported by the hook); from
# elsewhere pass -w and cd to the tree so relative paths resolve alike.

# -h/--help: print this script's header comment (its full reference), then exit.
case ${1:-} in -h|--help) exec awk 'NR==1&&/^#!/{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0" ;; esac
LVI=${LVI:-lvi}
store=${LVI_POS_FILE:-${XDG_STATE_HOME:-$HOME/.local/state}/lvi/positions}
maxn=${LVI_POS_MAX:-1000}

want_wid=; [ "$1" = "-w" ] && { want_wid=$2; shift 2; }
sub=${1:-}; [ -n "$sub" ] && shift
# restore [-j]: default sets the `" mark without moving the cursor; -j/--jump
# also moves there (THE CONFLICT in the header covers why -j belongs on `ready`
# only). -n/--no-jump is the old spelling of today's default, a compat no-op.
jump=
case "$1" in
  -j|--jump)    jump=1; shift ;;
  -n|--no-jump) shift ;;                    # now the default; kept as a compat no-op
esac
target=${want_wid:-${LVI_WID:-auto}}
send() { "$LVI" -w "$target" --detach -- "$@"; }

# Validate the subcommand before touching the socket, so a typo reports usage
# rather than silently no-op'ing on the (later) empty-file guard.
case "$sub" in
  save|restore) ;;
  *) echo "usage: lvi-pos [-w auto|WID] save | restore [-j]" >&2; exit 2 ;;
esac

# The buffer's file: from the env when spawned by a hook, else ask over the
# socket. No name -> nothing to key on, so quietly do nothing (a hook must not
# be noisy). Absolutise so the key is stable across launch directories.
# `-` not `:-`: a hook always exports LVI_FILE (empty for an unnamed buffer, which
# we then skip); only a manual run from another terminal leaves it unset -> ask.
file=${LVI_FILE-$("$LVI" -w "$target" -- path)}
[ -n "$file" ] || exit 0                      # pathless buffer: nothing to key on
case "$file" in /*) ;; *) file="$PWD/$file" ;; esac

# Skip volatile files, the way viminfo skips gitcommit/gitrebase and temp edits:
# a remembered position there is meaningless (a fresh COMMIT_EDITMSG every time).
case "${file##*/}" in COMMIT_EDITMSG|MERGE_MSG|TAG_EDITMSG|git-rebase-todo|*.tmp) exit 0 ;; esac
case "$file" in /tmp/*) exit 0 ;; esac

case "$sub" in
save)
  line=${LVI_LINE:-1}; col=${LVI_COL:-1}
  case "$line" in ''|*[!0-9]*) line=1 ;; esac
  case "$col"  in ''|*[!0-9]*) col=1  ;; esac
  # A glance at a file (open, don't move, leave -- the bufleave save) reports
  # line 1, and restore ignores line-1 entries as worthless; saving one would
  # only overwrite a remembered deep position with nothing.
  [ "$line" = 1 ] && exit 0
  mkdir -p "$(dirname "$store")" 2>/dev/null || exit 0
  tmp=$(mktemp "$store.XXXXXX") || exit 0
  trap 'rm -f "$tmp"' EXIT INT TERM
  # Drop any old entry for this file, append the fresh one, keep the newest maxn.
  # awk keys on the whole first field, so a path with spaces is fine (only the
  # tab separates columns). mv makes the replacement atomic.
  { awk -F'\t' -v f="$file" '$1 != f' "$store" 2>/dev/null
    printf '%s\t%s\t%s\n' "$file" "$line" "$col"
  } | tail -n "$maxn" >"$tmp" && mv "$tmp" "$store"
  ;;
restore)
  # Only act on a buffer at line 1 (a fresh read); a revisited buffer already
  # carries lvi's live cursor -- leave it be (see header).
  case "${LVI_LINE:-1}" in 1|"") ;; *) exit 0 ;; esac
  line=$(awk -F'\t' -v f="$file" '$1 == f { print $2 }' "$store" 2>/dev/null)
  case "$line" in ''|*[!0-9]*|0|1) exit 0 ;; esac      # nothing worth jumping to
  col=$(awk -F'\t' -v f="$file" '$1 == f { print $3 }' "$store" 2>/dev/null)
  case "$col" in ''|*[!0-9]*|0) col=1 ;; esac          # older/short entries -> column 1
  # Drop the `" mark at the exact spot: `:mark " LINE COL` is byte-exact and
  # moves nothing; it clamps a stale line/col (the file shrank since we saved)
  # into the buffer, the same tolerance as viminfo. With -j, :pos also moves
  # the cursor there -- one connection for both commands, so the order is
  # pinned (and a plain restore exits 0 either way).
  if [ -n "$jump" ]; then send "mark \" $line $col" "pos $line $col"
  else send "mark \" $line $col"; fi
  ;;
esac
