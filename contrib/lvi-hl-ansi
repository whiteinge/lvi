#!/usr/bin/env luajit
-- lvi-hl-ansi -- shared ANSI-color -> lvi :hl parser, reused by every ANSI
-- highlighting backend (bat, source-highlight, tree-sitter highlight, ...).
--
-- Reads ANSI-colored text on stdin and prints `hi synN sgr=<params>` +
-- `hl synN L:C1-C2 ...` ex commands. An ANSI backend has already chosen colors
-- (there are no semantic token groups), so each distinct SGR becomes a numbered
-- group `synN` whose style IS that SGR -- lvi just reproduces what the
-- highlighter drew (theming lives in the backend's theme, not lvi's :hi).
--
-- Written in LuaJIT so it adds no dependency beyond lvi's own runtime. Columns
-- are BYTES (1-based): escapes don't advance the column and text bytes do, so
-- the spans line up with lvi's byte-indexed overlay and multibyte text is
-- handled for free (each byte of a char is a byte column).
--
-- SGR model: a token-wrapped stream (SET.. text ..RESET), which bat and
-- source-highlight emit -- `ESC[0m`/`ESC[m` reset to default, any other `ESC[..m`
-- replaces the current style. Incrementally-composed SGR (separate bold then
-- color escapes) isn't merged; fine for these backends. Non-SGR escapes (cursor
-- moves etc.) are skipped. The backend must not re-wrap long lines (pass its
-- --wrap=never) or expand tabs (--tabs=0), or byte columns would desync.

-- -h/--help: print this script's header comment (its full reference), then exit.
if arg[1] == "-h" or arg[1] == "--help" then
  for line in io.lines(arg[0]) do
    if line:sub(1, 2) == "#!" then                        -- skip the shebang
    elseif line:sub(1, 2) == "--" then print((line:gsub("^%-%- ?", "")))
    else break end
  end
  os.exit(0)
end

local MAX = 64            -- distinct styles tracked; also the range cleared per run

local data = io.read("*a") or ""
local slot_of, order, spans, count = {}, {}, {}, 0

local function slot(sgr)
  local s = slot_of[sgr]
  if s then return s end
  if count >= MAX then return nil end
  s, count = count, count + 1
  order[s], slot_of[sgr], spans[s] = sgr, s, {}
  return s
end

local function add(s, line, c1, c2)          -- record a byte, merging contiguous runs
  local lst = spans[s]
  local last = lst[#lst]
  if last and last[1] == line and c1 == last[3] + 1 then last[3] = c2
  else lst[#lst + 1] = { line, c1, c2 } end
end

local cur, line, col = nil, 1, 1
local i, n = 1, #data
while i <= n do
  local b = data:byte(i)
  if b == 27 and data:byte(i + 1) == 91 then          -- ESC [   (CSI)
    local j = i + 2
    while j <= n do local c = data:byte(j); if c >= 0x40 and c <= 0x7e then break end; j = j + 1 end
    if data:byte(j) == 109 then                       -- final 'm' -> SGR
      local params = data:sub(i + 2, j - 1)
      if params == "" or params == "0" then cur = nil else cur = params end
    end
    i = j + 1
  elseif b == 10 then                                 -- newline
    line, col, i = line + 1, 1, i + 1
  else
    if cur then local s = slot(cur); if s then add(s, line, col, col) end end
    col, i = col + 1, i + 1
  end
end

local out = {}
for s = 0, count - 1 do
  out[#out + 1] = "hi syn" .. s .. " sgr=" .. order[s]
  local specs = {}
  for _, r in ipairs(spans[s]) do specs[#specs + 1] = r[1] .. ":" .. r[2] .. "-" .. r[3] end
  out[#out + 1] = "hl syn" .. s .. " " .. table.concat(specs, " ")
end
for s = count, MAX - 1 do out[#out + 1] = "hl syn" .. s end   -- clear stale slots
io.write(table.concat(out, "\n"), "\n")
