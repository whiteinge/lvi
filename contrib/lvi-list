#!/bin/sh
# lvi-list -- external quickfix/location lists for lvi.
#
# A "list" is a plain file of `file:line[:col]:text` entries (grep -Hn / compiler
# / linter output -- the vim -q format), each optionally followed by indented
# body lines (a compiler note, a multi-line diagnostic) that `preview` shows on
# demand -- n/N step the headers and skip the bodies. lvi knows nothing of lists:
# this script owns them, and drives lvi purely through the socket -- jumping the
# cursor, painting the :hl overlay, and setting a :status segment. Multiple named
# lists coexist; one is "focused" and the bare step commands act on it.
#
#   producer | lvi-list put NAME [--focus] [--at-cursor]   entries on stdin -> a list
#                                              (--at-cursor: seed the step index from
#                                              the cursor -- for producers that REFRESH
#                                              a list mid-walk, so `next` continues
#                                              forward instead of restarting at 1)
#   lvi-list next|prev|nfile|pfile [NAME]     step (NAME defaults to the focused list)
#   lvi-list here [NAME]                       jump to the first entry at/after the cursor
#   lvi-list preview [NAME]                    print the current entry + its body to stdout
#                                              (NAME defaults to the last-stepped list;
#                                              bind it to a tmux popup -- see PREVIEW below)
#   lvi-list goto|switch                       fzf over entries / over list names
#   lvi-list focus [NAME] | ls | paint [NAME]
#   lvi-list hide [NAME]                       stop showing a list (keep it; n/N re-show)
#   lvi-list save NAME PATH | load PATH [NAME] [--focus] | drop NAME | clear NAME | path NAME
#
# WHERE LISTS LIVE: beside the view's socket, derived from $LVI_SOCK
# (`.../lvi-$uid/$wid`) so the path can never drift from the one the editor chose:
#   $LVI_SOCK.lists/<name>        the entries (raw; multi-line bodies kept)  (per view)
#   $LVI_SOCK.lists/<name>.cur    the current index  (1-based; 0 = before first)
#   $LVI_SOCK.focus               the focused list name
# $wid.lists is a directory, so socket discovery (which filters `[ -S ]`) skips it.
# Persistent lists escape this disposable tree via `save`/`load` to any path.
#
# THREE SPAWN DISCIPLINES (why the callbacks all use --detach):
#   * stepping is bound to a key and runs under `:silent !` -- lvi's loop is
#     FROZEN waiting on us, so a call that *awaited* a reply would deadlock. We
#     never read editor state while stepping (the cursor lives in our sidecar,
#     the cursor's world in $LVI_* env), and every jump/paint is fire-and-forget
#     (`lvi -w --detach`): it buffers on the socket and lands the instant lvi
#     resumes. Same shape as lvi-open.
#   * `paint` is also run from `:on bufenter` (via spawn_bg -- loop stays live),
#     where --detach is simply harmless.
#   * producers that must READ the buffer (grep %p) self-background instead; see
#     lvi-search. lvi-list never reads the buffer.
#
# PREVIEW (two ways to read an entry): stepping echoes the current entry's TEXT
# (its file:line[:col]: prefix stripped -- you already know where you are) to lvi's
# message line via :msg -- ephemeral, persist-until-next-key, so your next motion
# clears it. The FULL entry (header + body) is `lvi-list preview` on stdout, meant
# to be bound to a tmux popup for the multi-line diagnostics:
#   map \m :silent !tmux display-popup -E "lvi-list -w $LVI_WID preview | less -R"<CR>
# With no name, `preview` targets the LAST-STEPPED list, not the focused one: `]e`
# steps `lint` without stealing n/N's focus, yet one \m should still show the lint
# entry you just navigated to. (Falls back through focus if nothing's been stepped.)
# Two gotchas the -E command must dodge (both bit the obvious version): the popup
# runs under the tmux SERVER, which does NOT inherit lvi's exported $LVI_SOCK /
# $LVI_WID -- so pass -w explicitly (the outer :silent ! shell, which DOES have
# them, expands it). And avoid $PAGER: zsh does not word-split it, so a `less
# -imMWR`-style value is run as one command name and fails -- name the pager plain.
# (:msge would flag it as an error; :msg is a neutral notice.)
#
# Config: LVI (client, default `lvi`), LVI_PICKER (fzf/fzy/sk, default fzf).
# Run from inside lvi (a map) and $LVI_WID/$LVI_SOCK are already in the env; from
# another terminal, pass `-w auto|WID`.

# -h/--help: print this script's header comment (its full reference), then exit.
case ${1:-} in -h|--help) exec awk 'NR==1&&/^#!/{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0" ;; esac

LVI=${LVI:-lvi}
PICKER=${LVI_PICKER:-fzf}

die() { echo "lvi-list: $*" >&2; exit 1; }
usage() { echo "usage: lvi-list [-w auto|WID] SUBCOMMAND [args]" >&2; exit 2; }

# ---- resolve the target view + its list directory ---------------------------
want_wid=
[ "${1:-}" = "-w" ] && { want_wid=${2:-}; shift 2; }
sub=${1:-}; [ -n "$sub" ] || usage; shift

target=${want_wid:-${LVI_WID:-auto}}          # what we hand to `lvi -w`
if [ -n "$LVI_SOCK" ] && [ -z "$want_wid" ]; then
  sock=$LVI_SOCK                              # inside lvi: trust the exported socket
elif [ "$target" = auto ]; then
  n=$($LVI -l | grep -c .)
  [ "$n" = 1 ] || die "-w auto needs exactly one running view ($n found)"
  sock=$($LVI -l | cut -f2)
else
  sock=$($LVI -l | awk -F'\t' -v w="$target" '$1==w{print $2; exit}')
  [ -n "$sock" ] || die "no running view '$target'"
fi
listdir="$sock.lists"
focusfile="$sock.focus"
lastfile="$sock.last"                         # the list you most recently STEPPED (\m preview target)

# ---- small helpers ----------------------------------------------------------
send()      { $LVI -w "$target" --detach -- "$@"; }         # fire-and-forget (see header)
lf()        { printf '%s\n' "$listdir/$1"; }
count()     { n=$(hdrs "$1" | grep -c .); echo "${n:-0}"; }  # number of ENTRIES (headers)
hnr()       { hdrs "$1" | sed -n "${2}p"; }                  # raw line of entry $2's header
nth()       { r=$(hnr "$1" "$2"); [ -n "$r" ] && sed -n "${r}p" "$listdir/$1"; }  # $2's header line
etext()     { sed -E 's/^[^:]*:[0-9]+(:[0-9]+)?:?[[:space:]]*//'; }  # entry line -> its text (drop file:line[:col]:)
show_cur()  { last_set "$1"; c=$(getcur "$1"); [ "$c" -ge 1 ] && send "msg $(nth "$1" "$c" | etext)"; }  # on step: mark last-stepped + preview text
getcur()    { c=$(cat "$listdir/$1.cur" 2>/dev/null); case "$c" in ''|*[!0-9]*) echo 0;; *) echo "$c";; esac; }
setcur()    { printf '%s\n' "$2" > "$listdir/$1.cur"; }
focus_get() { cat "$focusfile" 2>/dev/null; }
focus_set() { printf '%s\n' "$1" > "$focusfile"; }
last_set()  { printf '%s\n' "$1" > "$lastfile"; }                 # a step -> "the list you care about"
last_get()  { l=$(cat "$lastfile" 2>/dev/null); [ -n "$l" ] && [ -f "$listdir/$l" ] && printf '%s\n' "$l"; }
names()     { [ -d "$listdir" ] && for f in "$listdir"/*; do case "$f" in *.cur|"$listdir"/'*') ;; *) [ -f "$f" ] && printf '%s\n' "${f##*/}";; esac; done; }

# Entry boundaries in vim's MULTI-LINE quickfix format: a `file:line[:col]:text`
# HEADER (digits right after the first colon) starts an entry; the lines after it,
# up to the next header or EOF, are its body (a compiler note, a lint detail). The
# shape is self-delimiting -- body lines lack it (they are indented or prose), so
# only an unindented body line that itself looks like `file:line:` is misread, and
# producers indent continuations. `hdrs` prints each header's raw line number;
# count/index step ENTRIES through it, `span` rebuilds one for `preview`. (The
# body used to be filtered off on ingest; now it rides along, skipped by n/N.)
hdrs() { awk '/^[^:]*:[0-9]+(:|$)/{print NR}' "$listdir/$1" 2>/dev/null; }
span() {                                                    # print entry $2: header + body
  s=$(hnr "$1" "$2"); [ -n "$s" ] || return 0
  e=$(hnr "$1" "$(($2 + 1))"); [ -n "$e" ] && e=$((e - 1)) || e='$'
  sed -n "${s},${e}p" "$listdir/$1"
}

# Current file: from the env when we were spawned by lvi (a map/hook), else ask.
curfile() {
  if [ -n "${LVI_FILE+x}" ]; then printf '%s\n' "$LVI_FILE"
  else $LVI -w "$target" -- f 2>/dev/null | sed -n 's/^"\(.*\)" [0-9]* lines$/\1/p'; fi
}

# Jump the editor to an entry (file:line[:col]:...). Skips :e when already
# there. The column rides `normal` keys: there is no ex spelling for "goto
# column" (a bare `|N` line falls through to the system ex as a no-op), and
# `l` steps characters, which tracks the byte columns producers emit through
# tabs where the display-column `|` motion would not (multibyte still drifts
# -- the usual byte-col caveat).
jump() {
  f=${1%%:*}; r=${1#*:}; ln=${r%%:*}; r=${r#*:}; c=${r%%:*}
  case "$c"  in ''|*[!0-9]*) c=1 ;; esac
  case "$ln" in ''|*[!0-9]*) return 0 ;; esac
  col="normal 0"; [ "$c" -gt 1 ] && col="normal 0$((c - 1))l"
  if [ -n "$f" ] && [ "$f" != "$(curfile)" ]; then send "e $f" "$ln" "$col"
  else send "$ln" "$col"; fi
}

# Repaint NAME's entries for the CURRENT buffer, mark the current entry, and set
# the status counter. Bound to :on bufenter for cross-file lists. Each entry is
# marked at its FIRST COLUMN (`L:1-1`) rather than the whole line: a reversed or
# colored leading cell reads as a poor-man's sign, where a whole-line style buries
# the very text you're scanning. Un-themed groups stay invisible (opt in via :hi).
paint() {
  name=$1; [ -f "$listdir/$name" ] || return 0
  cf=$(curfile)
  lines=$(awk -F: -v f="$cf" '/^[^:]*:[0-9]+(:|$)/ && $1==f{printf "%s:1-1 ", $2}' "$listdir/$name")
  [ -n "$lines" ] && send "hl $name $lines" || send "hl $name"
  cur=$(getcur "$name"); total=$(count "$name")
  ce=$(nth "$name" "$cur")
  if [ -n "$ce" ] && [ "${ce%%:*}" = "$cf" ]; then
    send "hl $name-cur $(printf '%s' "$ce" | awk -F: '{print $2":1-1"}')"
  else send "hl $name-cur"; fi
  send "status $name [$cur/$total] $name"
}

# ---- subcommands ------------------------------------------------------------
need_name() { n=$(if [ -n "${1:-}" ]; then printf '%s\n' "$1"; else focus_get; fi); [ -n "$n" ] || die "no list (name one, or focus one first)"; printf '%s\n' "$n"; }

case "$sub" in
  put)
    name=; dofocus=; atcur=
    for a in "$@"; do case "$a" in
      --focus)     dofocus=1 ;;
      --at-cursor) atcur=1 ;;
      *)           name=$a ;;
    esac; done
    [ -n "$name" ] || die "usage: lvi-list put NAME [--focus] [--at-cursor]"
    mkdir -p "$listdir"; cat > "$listdir/$name" || true       # store raw; hdrs finds the entries
    if [ -n "$atcur" ]; then
      # Seed the index from the cursor so a REFRESHING producer (spell after a
      # fix, lint on write) doesn't send the walk back to entry 1: cur = the
      # last entry at or before the cursor, so `next` continues with the first
      # one past it. Assumes the producer emits the current file's entries in
      # position order (ours all do); on a cross-file list the seed is the
      # last CURRENT-file entry at or before the cursor.
      cf=$(curfile)
      cl=${LVI_LINE:-}; cc=${LVI_COL:-}
      [ -n "$cl" ] || { set -- $($LVI -w "$target" -- pos); cl=${1:-1}; cc=${2:-1}; }
      i=$(awk -F: -v f="$cf" -v l="${cl:-1}" -v c="${cc:-1}" '
            /^[^:]*:[0-9]+(:|$)/ { n++
              if ($1==f && (($2+0)<(l+0) || (($2+0)==(l+0) && ($3+0)<=(c+0)))) hit=n }
            END{print hit+0}' "$listdir/$name")
      setcur "$name" "$i"
    else
      setcur "$name" 0                                        # a following `next` lands on 1
    fi
    [ -n "$dofocus" ] && focus_set "$name"
    paint "$name" ;;

  next|prev)
    name=$(need_name "${1:-}") || exit 1; total=$(count "$name")
    [ "$total" -gt 0 ] || die "$name is empty"
    cur=$(getcur "$name"); [ "$sub" = next ] && cur=$((cur+1)) || cur=$((cur-1))
    [ "$cur" -lt 1 ] && cur=1; [ "$cur" -gt "$total" ] && cur=$total
    setcur "$name" "$cur"; jump "$(nth "$name" "$cur")"; paint "$name"; show_cur "$name" ;;

  nfile|pfile)
    name=$(need_name "${1:-}") || exit 1; total=$(count "$name")
    [ "$total" -gt 0 ] || die "$name is empty"
    cur=$(getcur "$name"); [ "$cur" -ge 1 ] || cur=1
    curf=$(nth "$name" "$cur"); curf=${curf%%:*}
    dir=1; [ "$sub" = pfile ] && dir=-1
    i=$cur; target_i=
    while :; do
      i=$((i+dir)); [ "$i" -lt 1 ] && break; [ "$i" -gt "$total" ] && break
      ef=$(nth "$name" "$i"); ef=${ef%%:*}
      [ "$ef" != "$curf" ] && { target_i=$i; break; }
    done
    [ -n "$target_i" ] || { send "status $name [$cur/$total] $name (no more files)"; exit 0; }
    setcur "$name" "$target_i"; jump "$(nth "$name" "$target_i")"; paint "$name"; show_cur "$name" ;;

  here)
    name=$(need_name "${1:-}") || exit 1; [ -f "$listdir/$name" ] || die "$name is empty"
    cf=$(curfile); cl=${LVI_LINE:-$($LVI -w "$target" -- pos | cut -f1)}
    i=$(awk -F: -v f="$cf" -v l="$cl" '
          /^[^:]*:[0-9]+(:|$)/ { n++; if ($1==f && ($2+0)>=(l+0)) { print n; exit } }' "$listdir/$name")
    [ -n "$i" ] || i=1
    setcur "$name" "$i"; jump "$(nth "$name" "$i")"; paint "$name"; show_cur "$name" ;;

  preview)                                   # the full current entry (header + body) to stdout
    # Default to the LAST-STEPPED list, not the focused one: `]e` steps lint
    # without stealing n/N's focus, yet \m should still show the lint entry you
    # just navigated to. Fall back through focus when nothing's been stepped.
    name=${1:-$(last_get)}; [ -n "$name" ] || name=$(focus_get)
    [ -n "$name" ] || die "no list stepped yet (step one, or name it)"
    [ -f "$listdir/$name" ] || die "$name is empty"
    cur=$(getcur "$name"); [ "$cur" -ge 1 ] || die "$name: step into the list first"
    span "$name" "$cur" ;;

  goto)
    name=$(need_name "${1:-}") || exit 1; [ -f "$listdir/$name" ] || die "$name is empty"
    # "N: file:line:..." -- a self-contained line the index is parsed back off,
    # so any $LVI_PICKER works: no fzf-only --with-nth/--delimiter (fzy, a plain
    # line filter, rejects them). The visible index just numbers the entries.
    sel=$(awk '/^[^:]*:[0-9]+(:|$)/{printf "%d: %s\n", ++n, $0}' "$listdir/$name" \
            | "$PICKER") || exit 0
    i=${sel%%:*}
    [ -n "$i" ] && { setcur "$name" "$i"; jump "$(nth "$name" "$i")"; paint "$name"; show_cur "$name"; } ;;

  switch)
    name=$(names | "$PICKER") || exit 0
    [ -n "$name" ] && { focus_set "$name"; paint "$name"; } ;;

  focus)
    if [ -n "${1:-}" ]; then focus_set "$1"; paint "$1"; else focus_get; fi ;;

  paint)                                     # :on bufenter -> repaint all lists
    if [ -n "${1:-}" ]; then paint "$1"; else names | while IFS= read -r nm; do paint "$nm"; done; fi ;;

  ls)
    f=$(focus_get); names | while IFS= read -r nm; do
      mark=" "; [ "$nm" = "$f" ] && mark="*"
      printf '%s %s\t%s\n' "$mark" "$(count "$nm")" "$nm"
    done ;;

  save) name=${1:?usage: save NAME PATH}; dest=${2:?usage: save NAME PATH}; cp "$listdir/$name" "$dest" ;;
  load)
    src=${1:?usage: load PATH [NAME] [--focus]}
    name=${2:-$(basename "$src")}; case "$name" in --focus) name=$(basename "$src");; esac
    mkdir -p "$listdir"; cp "$src" "$listdir/$name" || true; setcur "$name" 0
    case " $* " in *" --focus "*) focus_set "$name" ;; esac
    paint "$name" ;;

  drop|clear|hide)
    # All three unpaint (clear the :hl groups + status); they differ in what they
    # do to the stored list: drop removes it, clear empties it, hide keeps it
    # whole (cursor + focus intact) so `n`/`N` re-show it -- a per-list :nohl.
    name=$(need_name "${1:-}") || exit 1
    case "$sub" in
      drop)  rm -f "$listdir/$name" "$listdir/$name.cur" ;;
      clear) : > "$listdir/$name"; setcur "$name" 0 ;;
      hide)  : ;;
    esac
    send "hl $name"; send "hl $name-cur"; send "status $name" ;;

  path) name=${1:?usage: path NAME}; printf '%s\n' "$listdir/$name" ;;

  *) usage ;;
esac
