#!/bin/sh
# lvi-mirror [WID] -- mirror a running lvi's live buffer into every OTHER view
# open on the same file, so an edit in one tmux pane appears in the others.
#
# lvi has no in-editor multi-window: tmux (or any multiplexer) owns the panes,
# each running its own `lvi thefile` as a separate process with its own buffer
# and socket. This script connects them. It pulls the LIVE buffer over the
# control socket (so UNSAVED edits propagate, which a file-watch + :e never
# could) and writes it into the peers, also over the socket. Peers are matched
# by canonicalized filename.
#
# TURN IT ON. Two lines in ~/.lvirc, in EVERY pane:
#
#     on change lvi-mirror      " propagate edits as they settle
#     on write  lvi-mirror      " propagate the saved/clean state on :w
#
# Every pane carries the identical hook; the mesh is stable by construction and
# no instance needs to know the topology. It pushes only the changed hunks (via
# POSIX `diff`), not the whole buffer, so a peer's untouched lines keep their
# marks, highlights, and scroll, and its modified flag stays in sync.
#
# It self-backgrounds (double-fork) so a foreground `:silent !` map returns at
# once and lvi can resume to service the worker's socket reads. Run the worker
# directly to debug:
#
#     lvi-mirror --worker WID          # LVI_MIRROR_DEBUG=/path captures stderr
#
# LIMITS (by design, for now):
#   * Matched by filename, so an unnamed ([No File]) buffer can't mirror, and
#     two panes must have opened the SAME path (cwd differences are fine; a
#     hardlink under two names is not).
#   * One human, several viewports: last-writer-per-settle wins. Two panes
#     typing into the same region within one 150ms window can lose an update;
#     there is no OT/CRDT here and there won't be.
#   * A settle's whole push is ONE undo step on the peer, and undo (a keyboard
#     act) itself mirrors back, so undo is quasi-global. Know this before
#     leaning on it.
#   * `:wq`/`:x` fire write, but the pane is exiting: its socket closes before
#     the worker can read it back, so the FINAL save may not clear the peers'
#     flags. A plain `:w` (pane stays open) propagates reliably; that's the norm.
#
# Config (env): LVI (client, default `lvi`); LVI_MIRROR_MAXBYTES (skip buffers
# larger than this; default 262144); LVI_MIRROR_DEBUG (capture worker stderr).

# -h/--help: print this script's header comment (its full reference), then exit.
case ${1:-} in -h|--help) exec awk 'NR==1&&/^#!/{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0" ;; esac
LVI=${LVI:-lvi}
MAXBYTES=${LVI_MIRROR_MAXBYTES:-262144}

# First entry: detach a worker (double-fork -> no zombie for the calling lvi) and
# return immediately so lvi can resume and service the worker's socket reads.
if [ "$1" != "--worker" ]; then
  ("$0" --worker "$@" >"${LVI_MIRROR_DEBUG:-/dev/null}" 2>&1 &)
  exit 0
fi
shift

wid=${1:-$LVI_WID}
[ -n "$wid" ] || { echo "lvi-mirror: no WID (pass one or run from inside lvi)" >&2; exit 1; }
command -v diff >/dev/null 2>&1 || { echo "lvi-mirror: diff not found on PATH" >&2; exit 1; }

# Canonicalize a path so two panes launched from different directories still
# match. realpath -m tolerates a not-yet-saved file; without realpath we compare
# raw (works when both panes used the same spelling). Empty (a pathless buffer)
# or a bracketed display name (as `lvi -l`'s file column shows for one) -> fail.
canon() {
  case "$1" in ''|'['*']') return 1 ;; esac
  if command -v realpath >/dev/null 2>&1; then
    realpath -m -- "$1" 2>/dev/null || printf '%s\n' "$1"
  else
    printf '%s\n' "$1"
  fi
}

# Our own file (env when spawned by lvi; else ask the view).
myfile=${LVI_FILE:-$("$LVI" -w "$wid" -- path)}
mycanon=$(canon "$myfile") || { echo "lvi-mirror: view $wid has no filename; nothing to mirror" >&2; exit 0; }

# Stage OUR buffer once (peers read new lines out of it via sed) and a scratch
# file we rewrite with each peer's OLD content to diff against. They carry
# buffer text, so they live beside the socket in lvi's private per-uid dir (all
# of a uid's views share the dir), never the shared /tmp. Captured by redirect,
# not command substitution: $(...) strips trailing newlines, which would hide
# trailing blank lines from the diff and leave the peers diverged forever.
sock=${LVI_SOCK:-$("$LVI" -l | awk -F'\t' -v w="$wid" '$1==w{print $2; exit}')}
[ -n "$sock" ] || { echo "lvi-mirror: no running view '$wid'" >&2; exit 1; }
newf=$(mktemp "${sock%/*}/lvi-mirror.new.XXXXXX") || exit 1
oldf=$(mktemp "${sock%/*}/lvi-mirror.old.XXXXXX") || exit 1
trap 'rm -f "$newf" "$oldf"' EXIT
"$LVI" -w "$wid" -- '%p' > "$newf" || { echo "lvi-mirror: cannot read view $wid" >&2; exit 1; }

nbytes=$(wc -c < "$newf")
if [ "$nbytes" -gt "$MAXBYTES" ]; then
  echo "lvi-mirror: ${nbytes}B over cap ${MAXBYTES}B; skipping (raise LVI_MIRROR_MAXBYTES)" >&2
  exit 0
fi

# THE ECHO CHECK. A push ends with `fire` (below), which re-runs the
# destination's own `on change lvi-mirror` -- this run, one settle later. Each
# push records a hash of what it delivered, keyed by the destination's wid;
# our content still matching that record marks this run as the echo. An echo
# must never push CONTENT: its text is by definition one settle old, and the
# origin pane's human may have typed on past the settle -- diffing their newer
# text against ours would push back a REVERT of the newest keystrokes, the
# read-to-write gap the state-ownership razor says a script cannot lock.
# Content the keyboard has since changed hashes differently and propagates
# normally. A dirty echo has nothing else to say and exits here; a clean one
# still owes the flag sync below (a :w in the RECEIVING pane must clear its
# in-sync peers), so it goes on in flag-only mode. The records are tool-owned
# state beside the sockets; reap the ones whose views are gone (lvi-diff's
# launch-time GC discipline -- no daemon owns their lifetime).
myhash=$(cksum < "$newf")
pushedf="${sock%/*}/lvi-mirror.pushed"
echo_run=
[ "$myhash" = "$(cat "$pushedf.$wid" 2>/dev/null)" ] && echo_run=1
mymod=$("$LVI" -w "$wid" -- 'set modified?' 2>/dev/null)   # modified|nomodified ('' if unsupported)
[ -n "$echo_run" ] && [ "$mymod" != nomodified ] && exit 0
live=$("$LVI" -l | cut -f1)
for f in "$pushedf".*; do
  [ -e "$f" ] || continue
  printf '%s\n' "$live" | grep -qxF "${f##*.}" || rm -f "$f"
done
q=\'   # single-quote, to wrap the filename inside the awk-emitted commands

# Fan out to every OTHER live view whose (canonicalized) file matches ours.
# `lvi -l`'s third column carries each view's file, so the whole scan is one
# call -- no per-peer socket round-trip just to ask.
"$LVI" -l | while IFS='	' read -r peer _sock pfile; do
  [ -n "$peer" ] && [ "$peer" != "$wid" ] || continue
  pcanon=$(canon "$pfile") || continue
  [ "$pcanon" = "$mycanon" ] || continue

  set --   # accumulate this peer's commands: content hunks, cursor, then flag
  pushed=  # set when the batch carries content (then the push gets recorded)

  "$LVI" -w "$peer" -- '%p' > "$oldf" || continue
  if ! cmp -s "$oldf" "$newf"; then       # content differs: build the diff hunks
  [ -n "$echo_run" ] && continue          # an echo never pushes content; this peer moved on
  pushed=1

  # Peer cursor, so we can put it back after :d/:r have moved it.
  pos=$("$LVI" -w "$peer" -- pos)
  line=$(printf '%s' "$pos" | cut -f1); col=$(printf '%s' "$pos" | cut -f2)
  case "$line" in ''|*[!0-9]*) line=1 ;; esac
  case "$col"  in ''|*[!0-9]*) col=1  ;; esac

  # diff normal output. Command lines look like `2a3,4` / `3,5c3` / `4,6d3`:
  # <old-range><op><new-range>. Emit lvi commands in REVERSE hunk order so each
  # hunk's OLD-side addresses still refer to the pre-edit buffer when it runs.
  d=$(diff "$oldf" "$newf")

  while IFS= read -r c; do [ -n "$c" ] && set -- "$@" "$c"; done <<EOF
$(printf '%s\n' "$d" | awk -v newf="$newf" -v q="$q" '
    /^[0-9]/ {
      match($0, /[acd]/); op = substr($0, RSTART, 1)
      old = substr($0, 1, RSTART-1); new = substr($0, RSTART+1)
      oa = old; ob = old
      if (index(old, ",")) { oa = substr(old,1,index(old,",")-1); ob = substr(old,index(old,",")+1) }
      na = new; nb = new
      if (index(new, ",")) { na = substr(new,1,index(new,",")-1); nb = substr(new,index(new,",")+1) }
      n++; OA[n]=oa; OB[n]=ob; OP[n]=op; NA[n]=na; NB[n]=nb
    }
    END {
      # emit() threads `undojoin` between the commands, so the whole settle
      # reverts as ONE undo step on the peer instead of one per hunk command.
      # A change hunk reads the new lines in ABOVE, then deletes the old block
      # at its shifted address -- never delete-then-read: a change spanning the
      # whole buffer would empty it, the >=1-line invariant would leave one
      # blank line the read does not replace, and the peer would keep a phantom
      # trailing line forever (which also breaks the echo check: the content
      # no longer matches what the push recorded).
      for (i = n; i >= 1; i--) {
        if (OP[i] == "d") {
          emit(sprintf("%s,%sd _", OA[i], OB[i]))
        } else if (OP[i] == "a") {
          emit(sprintf("%s r !sed -n %s,%sp %s%s%s", OA[i], NA[i], NB[i], q, newf, q))
        } else {                                   # change: read new in, then delete old
          k = NB[i] - NA[i] + 1
          emit(sprintf("%s r !sed -n %s,%sp %s%s%s", OA[i]-1, NA[i], NB[i], q, newf, q))
          emit(sprintf("%s,%sd _", OA[i]+k, OB[i]+k))
        }
      }
    }
    function emit(s) { if (n_out++) print "undojoin"; print s }')
EOF

  # Shift the saved cursor by the net line-delta of hunks strictly above it, so
  # it follows its content across insertions/deletions higher in the file.
  adj=$(printf '%s\n' "$d" | awk -v cl="$line" '
    /^[0-9]/ {
      match($0, /[acd]/); op = substr($0, RSTART, 1)
      old = substr($0, 1, RSTART-1); new = substr($0, RSTART+1)
      oa = old+0; ob = oa
      if (index(old, ",")) { oa = substr(old,1,index(old,",")-1)+0; ob = substr(old,index(old,",")+1)+0 }
      na = new+0; nb = na
      if (index(new, ",")) { na = substr(new,1,index(new,",")-1)+0; nb = substr(new,index(new,",")+1)+0 }
      removed = (op == "a") ? 0 : (ob - oa + 1)
      added   = (op == "d") ? 0 : (nb - na + 1)
      if (op == "a") { if (oa < cl) delta += added }
      else if (ob < cl) { delta += (added - removed) }
      else if (oa <= cl && cl <= ob && !seen) { hit = na; seen = 1 }   # cursor line changed
    }
    END { print seen ? hit : cl + delta }')
  case "$adj" in ''|*[!0-9]*) adj=$line ;; esac

  # Hunks first, then the cursor restore: :pos is byte-exact (the same byte
  # columns `pos` reported) and clamps an over-range line/col. Last, `fire`
  # lets the peer's other change-hook consumers (live highlighting) see the
  # pushed text -- its own `on change lvi-mirror` re-runs too, and exits at
  # the echo check above against the record written below: it reads no one.
  set -- "$@" "pos $adj $col" fire
  fi

  # Flag sync: whenever WE are clean, make the (now in-sync) peer clean too. The
  # dirty direction needs nothing -- the splices above already did it.
  [ "$mymod" = nomodified ] && set -- "$@" "set nomodified"

  # One round-trip, in order: content, cursor, fire, flag. Skip if there's
  # nothing (and don't let the skip become the loop's exit status). A content
  # push that lands records what the peer now holds -- the echo check's key.
  [ $# -gt 0 ] || continue
  "$LVI" -w "$peer" -- "$@" || continue
  [ -n "$pushed" ] && printf '%s\n' "$myhash" > "$pushedf.$peer"
done
