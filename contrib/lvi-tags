#!/bin/sh
# lvi-tags [-w auto|WID] -- a ctags outline of the current file, in a fuzzy picker.
#
# Lists every tag defined in the CURRENT file, in file order, through a picker
# (fzf/fzy/sk); pick one and the view jumps to its line. Use it to jump straight
# to a function or section, or just scroll the picker as a structural overview.
# It tags the IN-MEMORY buffer, so it reflects your unsaved edits -- the point of
# driving a running editor. There is no `tags` file; ctags' stdout is read
# directly (see contrib/README.md for why no readtags).
#
# SYNOPSIS
#   map \t :wbuf<CR>:silent !lvi-tags<CR>   bind it inside lvi (keep the :wbuf)
#   lvi-tags -w auto|WID                    run from another terminal
#
# GETTING THE BUFFER. A picker needs the terminal, so the map runs under
# `:silent !`, which freezes lvi's event loop while we hold the tty -- a `%p`
# read back over the socket would deadlock. So the map dumps the buffer FIRST
# with lvi's `:wbuf` (writes $LVI_BUFFER), then hands us the tty; we read that
# file ($LVI_TAGS_DUMP overrides, else $LVI_BUFFER). Keep the :wbuf prefix, or
# the picker tags a stale snapshot -- possibly of a different buffer. Run from
# another terminal (-w WID), lvi is not frozen and $LVI_BUFFER is unset, so we
# read `%p` live over the socket instead.
#
# LANGUAGE DETECTION. ctags can't read a pipe and the dump file's name has no
# useful extension, so we copy the content into a temp file named with the
# buffer's basename -- that name lets ctags pick the language (it still reads the
# shebang/modeline from the content). An unnamed buffer can't be tagged; we bail.
#
# Each row shows the tag's definition line (ctags' search pattern), which makes
# the list read like an outline; rows sort by line number (`--fields=+n`) to keep
# file order. The jump uses --detach (fire-and-forget -- a synchronous reply would
# deadlock while lvi is frozen on us).
#
# Config: LVI (client, default `lvi`), LVI_PICKER (fzf/fzy/sk, default fzf),
# LVI_CTAGS (ctags binary, default `ctags`; wants Universal Ctags), LVI_TAGS_DUMP
# (buffer-snapshot file to read instead of $LVI_BUFFER/%p). Needs ctags and a
# picker on PATH. Run from inside lvi ($LVI_WID/$LVI_FILE/$LVI_BUFFER exported);
# from elsewhere pass -w and cd to the tree.

# -h/--help: print this script's header comment (its full reference), then exit.
case ${1:-} in -h|--help) exec awk 'NR==1&&/^#!/{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0" ;; esac
LVI=${LVI:-lvi}
PICKER=${LVI_PICKER:-fzf}
CTAGS=${LVI_CTAGS:-ctags}

die() { echo "lvi-tags: $*" >&2; exit 1; }

want_wid=; [ "$1" = "-w" ] && { want_wid=${2:-}; [ -n "$want_wid" ] || die "-w needs auto|WID"; shift 2; }
target=${want_wid:-${LVI_WID:-auto}}
send() { "$LVI" -w "$target" --detach -- "$@"; }

# The buffer's file: from the env when spawned by lvi (a map), else ask. We need
# the name only to detect the language (via the temp file's basename below).
file=${LVI_FILE:-$("$LVI" -w "$target" -- path)}
[ -n "$file" ] || die "buffer has no file name (need it to detect the language)"

# Get the buffer's text into a temp file named like the buffer, so ctags detects
# the language from the name (and the shebang/modeline in the content). Prefer a
# snapshot the binding already dumped ($LVI_TAGS_DUMP, else $LVI_BUFFER from
# :wbuf) -- reading %p while frozen under :silent ! would deadlock. With neither
# (run externally with -w), lvi is live, so read %p over the socket.
# The snapshot carries buffer text, so it lives beside the socket in lvi's
# private per-uid dir when we can name it, not in shared /tmp.
sockdir=${LVI_SOCK%/*}
if [ ! -d "$sockdir" ]; then
  s=$("$LVI" -l 2>/dev/null | sed -n 1p | cut -f2); sockdir=${s%/*}
fi
{ [ -n "$sockdir" ] && [ -d "$sockdir" ]; } || sockdir=${TMPDIR:-/tmp}
tmpd=$(mktemp -d "$sockdir/lvi-tags.XXXXXX") || die "mktemp failed"
trap 'rm -rf "$tmpd"' EXIT INT TERM
tmpf="$tmpd/$(basename "$file")"
dump=${LVI_TAGS_DUMP:-$LVI_BUFFER}
if [ -n "$dump" ] && [ -f "$dump" ]; then
  cp "$dump" "$tmpf" || die "could not read buffer snapshot $dump"
else
  "$LVI" -w "$target" -- %p >"$tmpf" || die "could not read buffer over the socket"
fi

# Tag the temp file to stdout. --fields=+n gives the line number; the tag
# address (field 3) carries the line number and the definition-line pattern.
# Pseudo (!_TAG) lines don't reach stdout, but we skip them defensively.
rows=$($CTAGS -f - --sort=no --fields=+n "$tmpf" 2>/dev/null | awk -F'\t' '
  /^!_TAG/ { next }
  NF >= 3 {
    name=$1; addr=$3; line=""; kind="?"
    la=addr; sub(/;.*/,"",la); if (la ~ /^[0-9]+$/) line=la      # line from the address
    def=addr
    sub(/^[0-9]*;?/,"",def); sub(/^\/\^?/,"",def)               # strip "NNN;/^"
    sub(/\$?\/;".*/,"",def)                                     # strip trailing "$/;" + fields
    gsub(/\\\//,"/",def)                                        # unescape \/ in the pattern
    for (i=4;i<=NF;i++) {                                       # extension fields
      if ($i ~ /^kind:/)                    kind=substr($i,6)   #   long-form kind
      else if ($i ~ /^line:/ && line == "") line=substr($i,6)   #   line: backup
      else if ($i !~ /:/ && kind == "?")    kind=$i             #   bare single-letter kind
    }
    if (line == "") next
    printf "%s\t%s\t%s\t%s\n", line, kind, name, def
  }' | sort -n)

[ -n "$rows" ] || { send "status tags no tags for this buffer"; exit 0; }

# Show line + kind + name + its definition, keep the line number as column 1 so
# we can read it straight back off the selection.
sel=$(printf '%s\n' "$rows" | awk -F'\t' '{printf "%6s  %-4s %-24s %s\n", $1, $2, $3, $4}' | "$PICKER") || exit 0
line=$(printf '%s' "$sel" | awk '{print $1}')
case "$line" in ''|*[!0-9]*) exit 0 ;; esac
send "$line"                                          # tag is in this buffer -> just jump
