#!/bin/sh
# lvi-stagediff [FILE] -- `git add -p` by way of a side-by-side diff. Concept
# borrowed from Fugitive (and a Vim POC of the same name): stage hunks by getting
# them into an "index" pane, then writing that pane's whole content back as the
# git index blob. No partial-patch math -- the index simply becomes whatever text
# ends up in the left pane.
#
# It stands on lvi-diff (which must sit beside this script), and stands on ALL of
# it: highlighting, scrollbind, hunk nav (]c/[c), fold-unchanged (zx), and hunk
# MOVING (\dp/\do, g@) are lvi-diff's, unchanged. This script adds only the two
# git-specific pieces, both daemonless (one-shot setup + one `on write` hook):
#
#   * SEED -- the left ("index") pane is a scratch buffer filled from
#     `git show :PATH` (the staged version); the right pane is the working tree.
#     So the diff between them is exactly your UNSTAGED changes.
#   * REBLOB-ON-WRITE -- the index pane's whole text IS the staged content. :w on
#     the index pane hashes its file into a git blob and points the index at it
#     (`git hash-object -w` + `git update-index`). That `on write` hook is the
#     ONE staging path. Everything else is just editing a buffer:
#       - \dp (working pane) moves the hunk under the cursor onto the index pane;
#         \do pulls the index's version back onto the working pane. g@{motion} (or
#         :L1,L2bg lvi-stagediff --xfer-range ...) moves just a motion's span.
#       - These are ordinary, undoable buffer edits -- nothing touches git. Shuffle
#         hunks, `u` to back a move out, hand-edit the index -- then :w to stage
#         the exact state you've arrived at.
#
# So the model is one :w per pane: :w on the INDEX pane stages (reblob); :w on
# the WORKING pane saves the working file to disk as usual (no reblob hook
# there). Nothing is staged until you say so.
#
# Why reblob-the-whole-buffer rather than `git apply --cached` a patch: it can't
# misapply (no fuzz), composes trivially (stage another hunk = reblob again), and
# falls straight out of "the index pane's text IS the staged state."
#
# PARTIAL / ADJACENT HUNKS. \dp moves a whole diff-hunk, and `diff` coalesces two
# changes with no unchanged line between them into ONE hunk -- so \dp can't split
# them (neither can `git add -p`; that's what its `e` is for). Two outs:
#   * g@{motion} / :L1,L2bg -- move just the lines you name onto the index pane.
#     g@ is armed as an operatorfunc (g@ip, g@}, 3g@@); the typed form rides ex's
#     address grammar (:12,14bg lvi-stagediff --xfer-range ...). Both are lvi-diff's
#     --xfer-range; then :w on the index stages what you moved.
#   * Hand-edit -- the index pane is a live buffer: move the merged hunk with \dp,
#     delete back (or edit) the part you didn't mean, and :w. The blob is whatever
#     you leave, so any state you can type is a state you can stage.
#
# UNSTAGING. In-session: `u` on the index pane backs out a move you haven't :w'd
# yet (nothing was reblobbed). Already reblobbed: edit the index pane back to the
# version you want staged and :w (POC-style), or `git reset` out of band -- a
# dedicated per-hunk unstage-to-HEAD would want a HEAD-vs-index second mode (below).
#
# SYNOPSIS
#   lvi-stagediff FILE        open the index|working split for FILE and wire it up
#   lvi-stagediff             use $LVI_FILE (i.e. run it from a map inside lvi)
#   \dp     (working pane)    move the hunk under the cursor onto the index pane
#   \do     (working pane)    pull the index's version of the hunk back into working
#   g@{motion} (working pane) move the motion's line span onto the index pane
#   :w      (index pane)      STAGE the current index text
#   :w      (working pane)    save the working file to disk (no staging)
#   ]c / [c / zx (either)     next/prev hunk; fold unchanged (all from lvi-diff)
#
# THE g@ WIRING. --attach arms g@ on the working pane as lvi-diff's --xfer-range
# operatorfunc, with the index view + canonical pair baked in (an absolute $DIFF
# and an LVI= prefix so a custom $LVI propagates to the spawned child):
#     set operatorfunc=LVI=lvi /path/to/lvi-diff --xfer-range IDX IDX WORK
# g@ exports the motion's span as $LVI_LINE1/2 and the pane as $LVI_WID, which
# --xfer-range defaults to, so nothing is baked but the destination and the pair.
# To (re)bind it to a key, set operatorfunc and press g@ in one map (mind lvi's
# no-timeout maps: pick a key that isn't a prefix clash -- \dx keeps it in the
# \d diff family, beside \dp/\do):
#     map \dx :set operatorfunc=lvi-diff --xfer-range IDX IDX WORK<CR>g@
#
# Internal entry points (not for direct use): --attach IDX WORK TOP REPOPATH GITDIR
# wires staging onto two open views; --reblob GITDIR TOP REPOPATH is the index pane's
# `on write` hook (it hashes $LVI_FILE, the pane's just-written temp file). GITDIR is
# resolved once by the launcher and threaded down so the hook -- which runs in a new
# tmux window with a fresh env -- can reach a repo located only via env (bare repo +
# detached work tree, e.g. a $GIT_DIR/$GIT_WORK_TREE dotfiles checkout).
#
# LIMITS (MVP): one file, no directory/index browser; unstaging to HEAD is hand-
# edit + :w (see above) until a HEAD-vs-index mode lands. Conflicts are refused up
# front (resolve them first).

# -h/--help: print this script's header comment (its full reference), then exit.
case ${1:-} in -h|--help) exec awk 'NR==1&&/^#!/{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0" ;; esac
LVI=${LVI:-lvi}

# Index seeds carry staged file content, so they live beside the sockets in
# lvi's private per-uid dir, never shared /tmp: $LVI_SOCK when spawned from
# inside lvi, else a live view's socket dir, else create the dir the way
# path.lua does (the launcher usually runs before any view exists).
RUNDIR=${LVI_SOCK%/*}
if [ ! -d "$RUNDIR" ]; then
  s=$("$LVI" -l 2>/dev/null | sed -n 1p | cut -f2); RUNDIR=${s%/*}
fi
if ! { [ -n "$RUNDIR" ] && [ -d "$RUNDIR" ]; }; then
  base=${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}
  RUNDIR=${base%/}/lvi-$(id -u)
  [ -d "$RUNDIR" ] || mkdir -m 700 "$RUNDIR" 2>/dev/null || RUNDIR=${TMPDIR:-/tmp}
fi

# Single-quote a value for splicing into a shell-parsed hook/map line, so a
# path holding spaces or quotes survives the re-parse when the hook fires.
sq() { printf "%s" "$1" | sed "s/'/'\\\\''/g"; }

case "$0" in
  /*) SELF=$0 ;;
  *)  SELF=$(cd "$(dirname "$0")" && pwd)/$(basename "$0") ;;
esac
DIFF=$(dirname "$SELF")/lvi-diff        # the machinery we build on
command -v git >/dev/null 2>&1 || { echo "lvi-stagediff: git not found" >&2; exit 1; }

# reblob: the index pane's whole text IS the staged content -- write it as a git
# blob and point the index at it. Fired by the index pane's `on write` hook, so its
# backing temp file ($LVI_FILE) is fresh on disk and byte-exact -- lvi's :w round-
# trips noeol/CRLF, so we hash THAT file rather than reconstructing from :%p (which
# dropped the final newline and forced a trailing-newline assumption).
#
# GITDIR is passed in explicitly (resolved by the launcher, below) rather than left
# to ambient discovery: this hook runs in a fresh tmux window whose env is whatever
# tmux seeded, NOT the shell that launched us -- so a repo reachable only via env
# (a bare repo + detached work tree, e.g. a $GIT_DIR/$GIT_WORK_TREE dotfiles setup)
# is invisible here. --git-dir makes git find the object db and index regardless;
# we still `cd "$top"` so the $rp pathspec stays relative to the work-tree root.
reblob() {
  gitdir=$1; idxf=$2; top=$3; rp=$4
  [ -n "$idxf" ] && [ -f "$idxf" ] || { echo "lvi-stagediff: index file not on disk: $idxf" >&2; return 1; }
  mode=$(cd "$top" && git --git-dir="$gitdir" ls-files --stage -- "$rp" 2>/dev/null | awk '{print $1; exit}')
  [ -n "$mode" ] || mode=100644
  blob=$(cd "$top" && git --git-dir="$gitdir" hash-object -w -- "$idxf") || return 1
  (cd "$top" && git --git-dir="$gitdir" update-index --cacheinfo "$mode,$blob,$rp") || {
    echo "lvi-stagediff: update-index failed" >&2; return 1; }
  # An ephemeral :msg, not a status segment -- the confirmation must not
  # overwrite the pane's standing "[index -- ...]" label.
  [ -n "$LVI_WID" ] && "$LVI" -w "$LVI_WID" -- "msg staged $rp" >/dev/null 2>&1
  return 0
}

# --attach: run lvi-diff's full setup (highlighting, scrollbind, hunk nav/move,
# folds), then add the two staging pieces on top -- the `on write` reblob on the
# index pane and the g@ partial-stage operatorfunc on the working pane. A=idx=the
# index, B=work=the working tree (the order we hand lvi-diff).
attach() {
  idx=$1; work=$2; top=$3; rp=$4; gitdir=$5
  LVI="$LVI" "$DIFF" "$idx" "$work" || return 1
  # Staging is reblob-on-write: :w on the index pane stages its current text. So
  # \dp/\do (from lvi-diff) shuffle hunks as ordinary, undoable edits and nothing
  # touches git until you :w. The baked paths are single-quoted (sq): the hook
  # line is re-parsed by sh when it fires, and a repo path with a space would
  # otherwise mis-split -- silently, since hook output is discarded.
  "$LVI" -w "$idx"  -- "on write LVI='$(sq "$LVI")' '$(sq "$SELF")' --reblob '$(sq "$gitdir")' '$(sq "$top")' '$(sq "$rp")'" >/dev/null 2>&1
  # Partial (sub-hunk) staging: arm g@ on the working pane as lvi-diff's env-aware
  # --xfer-range (dest=idx, canonical pair idx,work), for peeling two changes `diff`
  # merged into one hunk. Still just a buffer edit; :w on the index stages it.
  "$LVI" -w "$work" -- "set operatorfunc=LVI='$(sq "$LVI")' '$(sq "$DIFF")' --xfer-range $idx $idx $work" >/dev/null 2>&1
  "$LVI" -w "$idx"  -- 'status stage [index -- \dp/\do shuffle, :w stages]' >/dev/null 2>&1
  "$LVI" -w "$work" -- 'status stage [working -- \dp stage a hunk, \do restore it]' >/dev/null 2>&1
}

# Sweep index seeds whose views are gone (no daemon to own their lifetime now).
gc_seeds() {
  live=$("$LVI" -l 2>/dev/null | cut -f1)
  for f in "$RUNDIR"/lvi-stage.idx.*; do
    [ -e "$f" ] || continue
    used=""
    for w in $live; do "$LVI" -w "$w" -- f 2>/dev/null | grep -qF "$f" && { used=1; break; }; done
    [ -n "$used" ] || rm -f "$f"
  done
}

case "$1" in
  # --reblob GITDIR TOP REPOPATH -- the index pane's `on write` hook; the index file is $LVI_FILE.
  --reblob)  shift; reblob "$1" "$LVI_FILE" "$2" "$3"; exit $? ;;
  --attach)  shift; attach "$@"; exit $? ;;
esac

# --- launcher -----------------------------------------------------------------
file=${1:-$LVI_FILE}
[ -n "$file" ] || { echo "lvi-stagediff: need a FILE (or run from a map, \$LVI_FILE)" >&2; exit 1; }
[ -f "$file" ] || { echo "lvi-stagediff: no such file: $file" >&2; exit 1; }

dir=$(dirname "$file")
top=$(cd "$dir" && git rev-parse --show-toplevel 2>/dev/null) || {
  echo "lvi-stagediff: not inside a git repository" >&2; exit 1; }
# Resolve the git dir HERE, in the launcher's env, and thread it down: the reblob
# hook runs in a new tmux window that won't inherit an env-only repo location (bare
# repo + detached work tree). Absolute so it survives the reblob hook's `cd "$top"`.
gitdir=$(cd "$dir" && git rev-parse --absolute-git-dir 2>/dev/null) || {
  echo "lvi-stagediff: cannot resolve git dir" >&2; exit 1; }
rp=$(cd "$dir" && git ls-files --full-name -- "$(basename "$file")")
[ -n "$rp" ] || { echo "lvi-stagediff: not tracked by git: $file" >&2; exit 1; }
if [ -n "$(cd "$top" && git ls-files --unmerged -- "$rp")" ]; then
  echo "lvi-stagediff: resolve merge conflicts in $rp first" >&2; exit 1
fi
[ -n "$TMUX" ] || { echo "lvi-stagediff: run inside tmux (it opens the split there)" >&2; exit 1; }

gc_seeds        # reap seeds from closed sessions before making a new one

# Seed the index pane from the staged blob (empty for a not-yet-staged new file).
idxtmp=$(mktemp "$RUNDIR/lvi-stage.idx.XXXXXX") || exit 1
(cd "$top" && git show ":$rp" 2>/dev/null) > "$idxtmp"

# Open the split: index (scratch) left, working file right. Snapshot the live wids
# first so we pick out exactly the two we just made (never trust `lvi -l | head`).
before=$("$LVI" -l | cut -f1 | sort)
win=$(tmux new-window -P -F '#{window_id}' "exec $LVI '$(sq "$idxtmp")'")
tmux split-window -h -t "$win" "exec $LVI '$(sq "$file")'"

# Wait for both new views to register, then map wid -> file via :f.
idx=""; work=""
i=0
while [ $i -lt 50 ]; do
  new=""
  for w in $("$LVI" -l | cut -f1); do
    printf '%s\n' "$before" | grep -qxF "$w" || new="$new $w"
  done
  for w in $new; do
    f=$("$LVI" -w "$w" -- f 2>/dev/null | sed -n 's/^"\(.*\)" .*/\1/p')
    case "$f" in
      "$idxtmp") idx=$w ;;
      *"$rp"|"$file") work=$w ;;
    esac
  done
  [ -n "$idx" ] && [ -n "$work" ] && break
  i=$((i + 1)); sleep 0.1
done
[ -n "$idx" ] && [ -n "$work" ] || { echo "lvi-stagediff: views did not come up" >&2; exit 1; }

exec "$SELF" --attach "$idx" "$work" "$top" "$rp" "$gitdir"
