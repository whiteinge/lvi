#!/bin/sh
# lvi-fold [-w auto|WID] [MODE] -- fold a running lvi from the outside.
#
# lvi owns the fold mechanism (collapse a range to one row, navigate it -- see
# `Folding` in lvi.1); this computes WHERE the folds go, reading the live buffer
# over the control socket and pushing ranges back as `:fold` commands (the way
# lvi-highlight pushes `:hl`). It reads the buffer with `%p`, so it folds UNSAVED
# content and the line numbers map straight back.
#
# MODE selects how ranges are found (default `marker`):
#   marker  -- vim-style {{{ ... }}} fold markers, nested by a simple stack. The
#              open/close strings come from $LVI_FOLD_MARKER (default "{{{,}}}"),
#              matched anywhere on a line (a trailing level digit like {{{1 is
#              ignored -- nesting comes from the markers themselves).
#   indent  -- fold each run of lines indented deeper than the line above it
#              (whitespace-block folding); blank lines don't break a block.
#   man     -- fold each rendered-manpage section body under its flush-left
#              ALL-CAPS heading for a navigable TOC. The heading pattern is
#              $LVI_FOLD_MANHEAD (default all-caps + spaces); headings matching
#              $LVI_FOLD_MANKEEP (default NAME/SYNOPSIS) stay unfolded so the
#              orientation sections read on open. Feed it man output with
#              overstrike stripped (see contrib/lvi-man).
#
# It replaces the view's folds each run (one `:foldset` with every range), so
# re-running after an edit re-folds cleanly and a range you already had keeps its
# open/closed state -- a re-run, or an `on bufenter` re-push after a buffer
# switch, never re-closes what you opened. NEW folds arrive CLOSED; open them with
# zo/zR, or bind zR to reveal-all.
#
# Bind it inside lvi (WID comes from $LVI_WID). It reads the buffer, so it can't
# run in the foreground of a `:silent !` -- that freezes lvi's event loop while
# the child waits on the socket (deadlock). Use `:bg` (detached, no tty handover),
# or let it self-background a --worker. In ~/.lvirc:
#
#     hi Folded fg=cyan italic          " optional: theme the summary bar
#     map zx :bg lvi-fold<CR>           " (re)fold by marker
#     map zX :bg lvi-fold indent<CR>    " (re)fold by indent
#                                       " (not zi -- that's the foldenable toggle)
#     on bufenter lvi-fold              " auto-fold a file as you enter it
#
# From another terminal, pass a WID: `lvi-fold -w auto` or `lvi-fold -w 1234`.
#
# Config (env): LVI (client, default `lvi`), LVI_FOLD_MARKER (open,close pair,
# default "{{{,}}}"), LVI_FOLD_MINLINES (skip folds smaller than this many lines,
# default 2), LVI_FOLD_MANHEAD (man-mode heading regex, default "^[A-Z][A-Z ]*$"),
# LVI_FOLD_MANKEEP (man-mode headings to leave unfolded, default NAME/SYNOPSIS),
# LVI_FOLD_DEBUG (a file to capture the worker's output).

# -h/--help: print this script's header comment (its full reference), then exit.
case ${1:-} in -h|--help) exec awk 'NR==1&&/^#!/{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0" ;; esac
LVI=${LVI:-lvi}
MARKER=${LVI_FOLD_MARKER:-'{{{,}}}'}
MINLINES=${LVI_FOLD_MINLINES:-2}
MANHEAD=${LVI_FOLD_MANHEAD:-'^[A-Z][A-Z ]*$'}
MANKEEP=${LVI_FOLD_MANKEEP:-'^(NAME|SYNOPSIS) *$'}

worker=; [ "$1" = "--worker" ] && { worker=1; shift; }
want_wid=; [ "$1" = "-w" ] && { want_wid=$2; shift 2; }
mode=${1:-marker}
case "$mode" in marker|indent|man) ;;
  *) echo "lvi-fold: unknown MODE '$mode' (marker|indent|man)" >&2; exit 2 ;;
esac
target=${want_wid:-${LVI_WID:-auto}}
wflag=; [ -n "$want_wid" ] && wflag="-w $want_wid"

# Detach the buffer-reading half; return at once so lvi's loop resumes and can
# service the worker's socket traffic (same discipline as lvi-search).
if [ -z "$worker" ]; then
  ( "$0" --worker $wflag "$mode" >"${LVI_FOLD_DEBUG:-/dev/null}" 2>&1 & )
  exit 0
fi

# --- worker ------------------------------------------------------------------
open=${MARKER%,*}
close=${MARKER#*,}

# Compute " L1,L2 L3,L4 ..." range specs from the live buffer. Each mode prints
# one "start end" pair per line; the trailer folds them into :fold's arg syntax.
ranges=$(
  "$LVI" -w "$target" -- %p | case "$mode" in
    indent)
      # One streaming pass with a stack of open folds (base indent, anchor
      # line): a non-blank line deeper than the previous one opens a fold
      # anchored at that previous line; returning to the base (or shallower)
      # closes it at the last non-blank line inside. Blank lines extend
      # whatever is open. O(n) -- this runs on every bufenter, and the naive
      # per-line rescan was O(n^2) on a file that is mostly one deep block.
      awk '
        /^[ \t]*$/ { next }
        {
          match($0, /^[ \t]*/); d = RLENGTH
          while (sp > 0 && d <= base[sp]) { if (pnb > start[sp]) print start[sp] + 1, pnb; sp-- }
          if (pnb && d > pd) { base[++sp] = pd; start[sp] = pnb }
          pnb = NR; pd = d
        }
        END { while (sp > 0) { if (pnb > start[sp]) print start[sp] + 1, pnb; sp-- } }' ;;
    man)
      # man mode: each flush-left heading opens a section; fold its body (the
      # lines up to the next heading) so the page collapses to a heading TOC.
      # Headings matching $LVI_FOLD_MANKEEP (NAME, SYNOPSIS) stay unfolded.
      awk -v re="$MANHEAD" -v keep="$MANKEEP" '
        $0 ~ re { hdr[++h] = NR; htext[h] = $0; next }
        END {
          hdr[h + 1] = NR + 1                       # sentinel past the last line
          for (i = 1; i <= h; i++) {
            if (keep != "" && htext[i] ~ keep) continue   # leave this section open
            s = hdr[i] + 1; e = hdr[i + 1] - 1       # body: heading+1 .. next-1
            if (e >= s) print s, e
          }
        }' ;;
    *)
      # marker mode: a stack of open-marker line numbers; each close pops one.
      # A close AFTER the open on the same line pairs with it right away (a
      # one-line fold, dropped by MINLINES) so it can't orphan a push that a
      # later close would mispair.
      awk -v o="$open" -v c="$close" '
        index($0, o) {
          stack[++sp] = NR
          if (index(substr($0, index($0, o) + length(o)), c)) { s = stack[sp--]; if (NR > s) print s, NR }
          next
        }
        index($0, c) { if (sp > 0) { s = stack[sp--]; if (NR > s) print s, NR } }
      ' ;;
  esac | awk -v min="$MINLINES" '$2 - $1 + 1 >= min { printf " %d,%d", $1, $2 }'
)

# One atomic replace: surviving ranges keep their open state, stale ones go,
# and there is no unfolded flash between a clear and a re-fold. Empty ranges
# means a bare `foldset` -- the spelling for "no folds found, clear them".
"$LVI" -w "$target" -- "foldset$ranges"
