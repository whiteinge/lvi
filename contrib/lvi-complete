#!/bin/sh
# lvi-complete -- insert-mode word completion from the open buffers, for lvi.
#
# The completer half of lvi's `on complete` funnel. lvi binds Ctrl-P/Ctrl-N in
# insert mode to the command registered with `on complete`; on the keypress it
# runs that command, handing it the token being typed and the text of ALL open
# buffers, and splices the command's stdout in over the token. This script is
# that command: it turns the buffer text into a de-duplicated word list, runs it
# through a fuzzy picker seeded with the token, and prints the chosen word.
#
# It reads from the environment + stdin that lvi's complete_run sets up:
#   stdin              every open buffer's text, CURRENT BUFFER FIRST
#   $LVI_COMPL_TOKEN   the non-blank run before the cursor (the fuzzy query, and
#                      what lvi replaces with our output)
#   $LVI_COMPL_LINE    the line's text up to the cursor (unused here; it's the
#                      hook a future dispatcher would classify on -- see below)
#   $LVI_COMPL_DIR     prev (Ctrl-P) or next (Ctrl-N); advisory, unused here
# Current-buffer-first + a stable de-dupe (awk keeps the first sighting) is what
# makes this buffer's own words sort ahead of the others -- no extra work.
#
# Turn it on in your rc:
#   on complete lvi-complete
#
# A NON-JARRING POPUP: by default the picker takes the whole terminal for a beat.
# Set LVI_COMPL_POPUP=1 and, inside tmux, it runs in a `display-popup` drawn OVER
# the editor instead (lvi stays on its alt screen under it -- see complete_run's
# keep=true). Any other overlay mechanism is a drop-in: the contract is just
# "read a list on stdin, print one line."
#
# A FUTURE DISPATCHER: because lvi exports $LVI_COMPL_LINE and the token carries
# its own shape, a smarter `on complete` script can pick a SOURCE by context with
# no menu -- a `/` in the token -> a path completer, `word.word` -> members, a
# bare identifier -> this. Each source is just another command with this same
# stdin/stdout contract; core never changes.
#
# Config: LVI_PICKER (fzf/fzy/sk, default fzf), LVI_COMPL_MIN (drop words shorter
# than this; default 2), LVI_COMPL_POPUP (tmux popup when set and $TMUX).
PICKER=${LVI_PICKER:-fzf}
MIN=${LVI_COMPL_MIN:-2}
token=${LVI_COMPL_TOKEN:-}

# Buffer text -> words (split on non-word chars) -> drop the too-short ones and
# the token itself (completing to what you already typed is pointless) -> de-dupe
# preserving first-seen order (current buffer first).
words=$(tr -cs 'A-Za-z0-9_' '\n' \
  | awk -v min="$MIN" -v t="$token" 'length($0) >= min && $0 != t && !seen[$0]++')
[ -n "$words" ] || exit 0

# Pick. -q seeds the query with the token (fzf/fzy/sk all accept -q), so the list
# opens already narrowed and you get fuzzy matching from there.
if [ -n "${LVI_COMPL_POPUP:-}" ] && [ -n "${TMUX:-}" ]; then
  # display-popup runs a separate command with its own tty, so hand the list in
  # and take the selection out through temp files.
  cf=$(mktemp) || exit 0; sf=$(mktemp) || { rm -f "$cf"; exit 0; }
  tf=$(mktemp) || { rm -f "$cf" "$sf"; exit 0; }
  printf '%s\n' "$words" > "$cf"; printf '%s' "$token" > "$tf"
  # display-popup runs its command in a fresh shell under the tmux SERVER, which
  # does NOT inherit the LVI_COMPL_* env lvi exported to us -- so $LVI_COMPL_TOKEN
  # would be empty there (a blank query). Pass the query through a file and read
  # it back quoted (`"$(cat ...)"`): no env, no quoting hazard for any token.
  tmux display-popup -E "$PICKER -q \"\$(cat '$tf')\" < '$cf' > '$sf'" </dev/null
  cat "$sf"
  rm -f "$cf" "$sf" "$tf"
else
  printf '%s\n' "$words" | "$PICKER" -q "$token"
fi
