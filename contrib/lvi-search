#!/bin/sh
# lvi-search [-w auto|WID] [-i] [PATTERN]
#
# Search a running lvi from outside it, as a `lvi-list` producer: grep the *live*
# buffer over the control socket, build the `search` list, focus it, and jump to
# the first match. `n`/`N` then step it like any other list -- search is just a
# degenerate quickfix. Because it reads the buffer via `%p` it searches UNSAVED
# content, and the line numbers map straight back. PATTERN is a POSIX grep BRE.
#
# Bind it inside lvi (WID comes from $LVI_WID). `/` prompts, so it needs the tty
# (`:silent !`); the rest touch no tty, so they use `:bg` -- a detached spawn with
# no terminal handover, which avoids the alt-screen flash when you hold n/N:
#     map / :silent !lvi-search<CR>          " prompt for a pattern
#     map * :bg lvi-search "$LVI_CWORD"<CR>  " search the word under the cursor
#     map n :bg lvi-list next<CR>            " step the focused list
#     map N :bg lvi-list prev<CR>
# From another terminal, pass a WID: `lvi-search -w auto foo`.
#
# It self-backgrounds a --worker: reading the buffer needs lvi's event loop,
# which is frozen while this `:silent !` child runs, so a foreground read would
# deadlock (same reason lvi-highlight self-backgrounds). The pattern PROMPT,
# though, runs in the foreground -- a backgrounded worker has no tty.
#
# Case: -i forces case-insensitive; LVI_SEARCH_CASE picks the default policy --
# `sensitive` (default), `ignore`, or `smart` (the vi/vim rule: insensitive unless
# PATTERN has an uppercase letter). Set it per binding to taste, e.g.
#     map / :silent !LVI_SEARCH_CASE=smart lvi-search<CR>
#
# Config: LVI (client, default `lvi`), LVI_SEARCH_CASE (sensitive|ignore|smart),
# LVI_SEARCH_DEBUG (capture worker stderr). Needs lvi-list on PATH.

# -h/--help: print this script's header comment (its full reference), then exit.
case ${1:-} in -h|--help) exec awk 'NR==1&&/^#!/{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0" ;; esac
LVI=${LVI:-lvi}

worker=; [ "$1" = "--worker" ] && { worker=1; shift; }
want_wid=; [ "$1" = "-w" ] && { want_wid=$2; shift 2; }
icase=; [ "$1" = "-i" ] && { icase=1; shift; }
pat=${1:-}
target=${want_wid:-${LVI_WID:-auto}}
wflag=; [ -n "$want_wid" ] && wflag="-w $want_wid"

# Prompt in the foreground (where `:!` handed us the tty). Skip when a pattern
# was supplied (e.g. `*` passes $LVI_CWORD) or when we are already the worker.
if [ -z "$worker" ] && [ -z "$pat" ]; then
  printf '/' >&2
  IFS= read -r pat || exit 0
  [ -n "$pat" ] || exit 0
fi

# Detach the buffer-reading half; return at once so lvi's loop resumes and can
# service the worker's socket traffic.
if [ -z "$worker" ]; then
  ( "$0" --worker $wflag ${icase:+-i} "$pat" >"${LVI_SEARCH_DEBUG:-/dev/null}" 2>&1 & )
  exit 0
fi

# --- worker ------------------------------------------------------------------
# The buffer's filename (entries are file:line:text so cross-file tools share the
# format). A pathless buffer -- unsaved, read from stdin, a scratch view -- shows
# a bracketed pseudo-name ([No Name], [stdin], [Command Line], ...); blank it so
# entries carry no file and lvi-list jumps stay put. Safe because lvi-search only
# ever matches THIS buffer, so a match never needs a cross-file :e in the first
# place -- and an :e of a pseudo-name would blank the buffer.
file=${LVI_FILE:-$($LVI -w "$target" -- f | sed -n 's/^"\(.*\)" [0-9]* lines$/\1/p')}
case "$file" in "["*"]") file= ;; esac

# Resolve case policy: an explicit -i wins, else LVI_SEARCH_CASE decides (smart
# looks for an uppercase letter in the pattern, so a locale-aware [[:upper:]]).
iflag=
if [ -n "$icase" ]; then
  iflag=-i
else
  case "${LVI_SEARCH_CASE:-sensitive}" in
    ignore) iflag=-i ;;
    smart)  case "$pat" in *[[:upper:]]*) ;; *) iflag=-i ;; esac ;;
  esac
fi

matches=$($LVI -w "$target" -- '%p' | grep -n $iflag -- "$pat")
if [ -z "$matches" ]; then
  $LVI -w "$target" --detach -- "hl search" "status search /$pat/ no match"
  exit 0
fi
# search owns its look so it shows without a theme (see CLAUDE.md); rc may override.
# pri=10 lifts the mark above syntax highlighting (pri 0) so it shows through a
# styled first column (e.g. a Markdown `1.` ordered-list marker).
$LVI -w "$target" --detach -- "hi search reverse pri=10"
printf '%s\n' "$matches" | awk -v f="$file" '{print f":"$0}' | lvi-list $wflag put search --focus
lvi-list $wflag next
