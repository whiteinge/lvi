#!/bin/sh
# lvi-highlight [WID] -- syntax-highlight a running lvi from the outside.
#
# The same approach as lvi-search: no in-editor language engine. This pulls the
# LIVE buffer over the control socket (so it highlights UNSAVED content), runs an
# external highlighter, and paints the result through lvi's styled :hl overlay.
# Whole tokens (including a still-open string or block comment) come back as
# spans, so an unclosed quote colors the rest of the file until you close it.
#
# SYNOPSIS
#   lvi-highlight [WID]          highlight the buffer now (default $LVI_WID)
#   lvi-highlight off|on|toggle  suppress / resume / flip highlighting (:syntax off)
#   lvi-highlight lang [NAME]    force the highlighter's language; bare `lang` clears
#   lvi-highlight --theme [WID]  seed group colors from a Pygments style, then exit
#   lvi-highlight --worker WID   run the buffer-reading half in front (measure/debug)
#
# Bind it inside lvi (styles + a trigger key), e.g. in ~/.lvirc:
#     hi Comment  fg=cyan italic      " define the theme once
#     hi String   fg=green
#     hi Keyword  fg=blue bold
#     hi Number   fg=magenta
#     hi Function fg=yellow
#     hi Type     fg=cyan
#     on change   lvi-highlight       " re-highlight a beat after you stop typing
#     on bufenter lvi-highlight       " ...and when you switch/open a buffer
#     map \hh :bg lvi-highlight<CR>   " ...and/or force it on a key (\h menu)
#     map \ht :bg lvi-highlight toggle<CR>   " :syntax off / on
# `change` is keyboard-only (a hook's own socket edits can't retrigger it, so no
# loop); pair it with `bufenter` so a socket-driven :e (e.g. lvi-open) highlights
# the file it lands on.
#
# THEME. The `hi` block above is optional: `lvi-highlight --theme` seeds the
# group colors from a Pygments built-in style (via $LVI_PYGMENTS_STYLE) in one
# shot, so `on ready LVI_PYGMENTS_STYLE=monokai lvi-highlight --theme` replaces
# the hand-written `hi` lines. It is a one-shot seed for `on ready`, not a
# per-change hook, and is backend-specific (pygments supports it).
#
# RUNTIME CONTROL. `off` clears the syntax groups and suppresses the hooks (a
# `:syntax off`), `on` re-enables, `toggle` flips. When detection guesses wrong,
# `lang NAME` forces the highlighter's language (e.g. `lang xml` for an .html
# buffer that is really XML) and a bare `lang` clears the override; run it from a
# :sh under lvi, e.g. `lvi-highlight lang xml`. State is per-view (for now), kept
# beside the socket ($LVI_SOCK.hl-off, $LVI_SOCK.hl-lang), so run these inside lvi.
#
# It self-backgrounds a --worker: reading the buffer needs lvi's event loop,
# which is frozen while a foreground `:silent !` child runs, so a foreground
# read would deadlock (the same reason lvi-open uses --detach); under :bg or a
# hook the detach is harmless, so any binding is safe. A skip or a config error
# lands in the `hl` status segment, cleared by the next successful paint.
#
# Config (env): LVI (client, default `lvi`), LVI_HL_BACKEND (adapter, default
# `pygments` -> contrib/lvi-hl-pygments), LVI_HL_MAXBYTES (skip buffers larger
# than this; whole-buffer lex is O(size); default 262144), LVI_HL_DEBUG (a file
# to capture the worker's stderr).

# -h/--help: print this script's header comment (its full reference), then exit.
case ${1:-} in -h|--help) exec awk 'NR==1&&/^#!/{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0" ;; esac
LVI=${LVI:-lvi}
BACKEND=${LVI_HL_BACKEND:-pygments}
MAXBYTES=${LVI_HL_MAXBYTES:-262144}
DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

# Runtime control (see RUNTIME CONTROL in the header). These manage per-view
# state beside the socket, then re-exec with no args to repaint (or clear, if we
# just turned highlighting off). They need $LVI_SOCK, so run them inside lvi.
case ${1:-} in
  on | off | toggle | lang)
    sub=$1; shift
    sock=${LVI_SOCK:-}
    [ -n "$sock" ] || { echo "lvi-highlight: '$sub' must run inside lvi (\$LVI_SOCK unset)" >&2; exit 1; }
    case "$sub" in
      on)     rm -f "$sock.hl-off" ;;
      off)    : > "$sock.hl-off" ;;
      toggle) if [ -f "$sock.hl-off" ]; then rm -f "$sock.hl-off"; else : > "$sock.hl-off"; fi ;;
      lang)   if [ -n "${1:-}" ]; then printf '%s' "$1" > "$sock.hl-lang"; else rm -f "$sock.hl-lang"; fi ;;
    esac
    exec "$0"      # repaint now, or clear if we just turned it off
    ;;
esac

# --theme [WID]: push the backend's `--theme` block (a Pygments built-in style,
# via $LVI_PYGMENTS_STYLE) over the socket, then exit -- a one-shot theme seed
# for `on ready`, not a per-change hook. No buffer read here, so no worker
# detach: `on ready` already runs us backgrounded, and lvi's poll loop is live
# to service the `hi` round-trip. Backend must support --theme (pygments does).
if [ "$1" = "--theme" ]; then
  wid=${2:-$LVI_WID}
  [ -n "$wid" ] || { echo "lvi-highlight: no WID (pass one or run from inside lvi)" >&2; exit 1; }
  adapter="$DIR/lvi-hl-$BACKEND"
  [ -x "$adapter" ] || { echo "lvi-highlight: no adapter for backend '$BACKEND' ($adapter)" >&2; exit 1; }
  set --
  while IFS= read -r cmd; do
    [ -n "$cmd" ] && set -- "$@" "$cmd"
  done <<EOF
$("$adapter" --theme)
EOF
  [ $# -gt 0 ] || {
    echo "lvi-highlight: backend '$BACKEND' --theme emitted nothing (bad LVI_PYGMENTS_STYLE?)" >&2
    "$LVI" -w "$wid" --detach -- "msge lvi-highlight: --theme emitted nothing (bad LVI_PYGMENTS_STYLE?)" 2>/dev/null
    exit 1
  }
  "$LVI" -w "$wid" -- "$@"
  exit $?
fi

# First entry: detach a worker (double-fork -> no zombie for the calling lvi)
# and return immediately so lvi can resume and service the worker's socket I/O.
if [ "$1" != "--worker" ]; then
  ("$0" --worker "$@" >"${LVI_HL_DEBUG:-/dev/null}" 2>&1 &)
  exit 0
fi
shift

wid=${1:-$LVI_WID}
[ -n "$wid" ] || { echo "lvi-highlight: no WID (pass one or run from inside lvi)" >&2; exit 1; }

adapter="$DIR/lvi-hl-$BACKEND"
[ -x "$adapter" ] || {
  echo "lvi-highlight: no adapter for backend '$BACKEND' ($adapter)" >&2
  # A status segment, not :msge: it repeats on every hook fire, and the next
  # successful paint clears it -- the lvi-diff over-cap pattern.
  "$LVI" -w "$wid" -- "status hl [lvi-highlight: no adapter '$BACKEND']" >/dev/null 2>&1
  exit 1
}

# Disabled via `lvi-highlight off`: clear every syntax group and stop. Empty
# input makes the adapter emit a bare `hl GROUP` for each group it owns.
if [ -n "${LVI_SOCK:-}" ] && [ -f "$LVI_SOCK.hl-off" ]; then
  set --
  while IFS= read -r cmd; do [ -n "$cmd" ] && set -- "$@" "$cmd"; done <<EOF
$(printf '' | "$adapter" "")
EOF
  "$LVI" -w "$wid" -- "$@" "status hl"
  exit 0
fi

# Live buffer + its filename (for language detection). Works on unsaved content.
text=$("$LVI" -w "$wid" -- '%p') || { echo "lvi-highlight: cannot read view $wid" >&2; exit 1; }
fname=$("$LVI" -w "$wid" -- path)          # empty for a pathless buffer

# Size cap: skip a buffer too big to lex on every trigger. The notice is a
# status segment (idempotent under repeated hook fires); the next successful
# paint -- the buffer shrank, or the cap was raised -- clears it.
nbytes=$(printf '%s' "$text" | wc -c)
if [ "$nbytes" -gt "$MAXBYTES" ]; then
  echo "lvi-highlight: ${nbytes}B over cap ${MAXBYTES}B; skipping (raise LVI_HL_MAXBYTES)" >&2
  "$LVI" -w "$wid" -- "status hl [lvi-highlight off: over ${MAXBYTES}B cap]" >/dev/null 2>&1
  exit 0
fi

# A forced language (`lvi-highlight lang NAME`) overrides the adapter's filename
# detection; empty means detect as before.
lang=; [ -n "${LVI_SOCK:-}" ] && [ -f "$LVI_SOCK.hl-lang" ] && lang=$(cat "$LVI_SOCK.hl-lang")

# Adapter: buffer on stdin, filename as $1, optional language as $2; emits one
# `hl GROUP specs` per group. Collect the lines and apply in one round-trip.
set --
while IFS= read -r cmd; do
  [ -n "$cmd" ] && set -- "$@" "$cmd"
done <<EOF
$(printf '%s' "$text" | "$adapter" "$fname" "$lang")
EOF

# One round-trip: the paint, plus clearing any earlier skip/error segment. Sent
# even with nothing to paint, so the segment can't stick -- and an empty paint
# is a success, not a worker error.
"$LVI" -w "$wid" -- "$@" "status hl"
