#!/bin/sh
# lvi-gitchanges [-w auto|WID] [--staged] [REF | REF..REF]
#
# Load the git changes for the CURRENT buffer as a `lvi-list` quickfix and jump
# to the first hunk; `n`/`N` then step them like any other list. A git producer
# in the same mold as lvi-search -- it turns `git diff` hunk headers into
# `file:line:text` entries, one per hunk, feeds them to `lvi-list`, and lets the
# shared step/paint/status machinery do the rest.
#
#   lvi-gitchanges              uncommitted changes to this file (working tree vs HEAD)
#   lvi-gitchanges --staged     STAGED changes to this file (index vs HEAD)
#   lvi-gitchanges HEAD~3..     changes across a commit range that touch this file
#   lvi-gitchanges abc123       changes introduced by a single commit (git show)
#   lvi-gitchanges --staged REF staged changes measured against REF (index vs REF)
#
# --staged is `git diff --cached`: it steps what you've staged, not what you've
# edited -- so after moving hunks onto the index in lvi-stagediff (each :w on the
# index pane stages), `lvi-gitchanges --staged` walks exactly those regions, folds
# and all. It loads into its OWN list (`gitstaged`), separate from the unstaged
# `gitchanges` list, so both can coexist and be themed and stepped independently.
# It's a snapshot, not a live view: rerun it to regenerate after staging more.
#
# SCOPE + PATHS: always the current file (`$LVI_FILE`), passed to git as a
# pathspec. Entries emit $LVI_FILE verbatim as the filename (not git's `b/...`
# path) so they always match what lvi calls the buffer -- the same trick
# lvi-search uses -- which is what lets `jump` skip a needless :e and `paint`
# light the changed lines in place.
#
# DISK, NOT BUFFER: git diffs the file ON DISK (or the index, with --staged), so
# this reflects your last :w / `git add`, not unsaved edits. Save/stage first if a
# hunk looks stale. --staged line numbers are index-side, so they best match the
# buffer when the staged and working versions agree (as they do right after you
# stage a hunk in lvi-stagediff). (Contrast lvi-search, which greps the live
# buffer via %p.)
#
# Bind it with :bg -- git is non-interactive so it needs no tty, and :bg avoids
# the alt-screen flash that :silent ! causes:
#     map \g :bg lvi-gitchanges<CR>       " load this file's changes, focus, jump
#     map \G :bg lvi-gitchanges --staged<CR>    " same, for STAGED changes
#     map ]c :bg lvi-list next gitchanges<CR>   " or step it without stealing focus
#     map [c :bg lvi-list prev gitchanges<CR>
# Theme the marks in your rc (un-themed = invisible; see lvi-list); give the two
# lists distinct colors so staged vs unstaged read apart at a glance:
#     hi gitchanges bg=22 pri=10
#     hi gitstaged  bg=28 pri=10
#
# Config: LVI (client, default `lvi`). Needs lvi-list and git on PATH. Run from
# inside lvi ($LVI_WID/$LVI_FILE are exported); from elsewhere pass -w and cd to
# the file's directory.

# -h/--help: print this script's header comment (its full reference), then exit.
case ${1:-} in -h|--help) exec awk 'NR==1&&/^#!/{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0" ;; esac
LVI=${LVI:-lvi}

die() { echo "lvi-gitchanges: $*" >&2; exit 1; }

want_wid=; [ "$1" = "-w" ] && { want_wid=$2; shift 2; }
staged=; case "${1:-}" in --staged|--cached) staged=1; shift ;; esac
ref=${1:-}
target=${want_wid:-${LVI_WID:-auto}}
wflag=; [ -n "$want_wid" ] && wflag="-w $want_wid"
name=gitchanges; [ -n "$staged" ] && name=gitstaged
send() { $LVI -w "$target" --detach -- "$@"; }

# The buffer's file: from the env when spawned by lvi (a map/hook), else ask.
file=${LVI_FILE:-$($LVI -w "$target" -- f | sed -n 's/^"\(.*\)" [0-9]* lines$/\1/p')}
case "$file" in ""|"[No File]"|"[No Name]") die "current buffer has no file" ;; esac

# Choose the diff. --staged -> index vs REF (HEAD by default), git's `--cached`.
# Otherwise: no ref -> working tree vs HEAD; a range -> that range; a lone commit
# -> just that commit (git show), mirroring the git-quickfix convention.
if [ -n "$staged" ]; then
  if [ -n "$ref" ]; then diff=$(git diff --cached -U0 "$ref" -- "$file" 2>/dev/null)
  else diff=$(git diff --cached -U0 -- "$file" 2>/dev/null); fi
elif [ -z "$ref" ]; then
  diff=$(git diff -U0 HEAD -- "$file" 2>/dev/null)
elif [ "${ref#*..}" != "$ref" ]; then
  diff=$(git diff -U0 "$ref" -- "$file" 2>/dev/null)
else
  diff=$(git show -U0 --first-parent -m "$ref" -- "$file" 2>/dev/null)
fi
[ $? -eq 0 ] || die "git failed (not a repo, or bad ref '$ref'?)"

# One entry per hunk: $LVI_FILE:<new-start>:+A -D  <section context>.
# @@ -a,d +s,i @@ ctx   (a comma-less count means 1; +s,0 is a pure deletion).
entries=$(printf '%s\n' "$diff" | awk -v f="$file" '
  /^@@ / {
    add=$3; sub(/^\+/,"",add); s=add
    if (add ~ /,/) { sub(/.*,/,"",add); sub(/,.*/,"",s) } else add=1
    if (s+0 < 1) s=1
    del=$2; sub(/^-/,"",del); if (del ~ /,/) sub(/.*,/,"",del); else del=1
    ctx=$0; sub(/^@@[^@]*@@ ?/,"",ctx)
    label=sprintf("+%d -%d", add, del)
    if (ctx != "") label=label "  " ctx
    printf "%s:%s:%s\n", f, s, label
  }')

if [ -z "$entries" ]; then
  send "hl $name" "hl $name-cur" "status $name no changes"
  exit 0
fi

printf '%s\n' "$entries" | lvi-list $wflag put "$name" --focus
lvi-list $wflag next
