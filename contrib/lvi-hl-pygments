#!/usr/bin/env python3
# lvi-hl-pygments -- Pygments syntax-highlighting adapter for lvi-highlight.
#
# Adapter contract (shared by every backend): read the buffer text on stdin,
# take the filename as argv[1] (may be empty) and an optional language name as
# argv[2] (overrides filename detection when set), and print `hl GROUP L:C1-C2 ...`
# ex commands on stdout -- byte columns, 1-based, one line per group. Columns
# are BYTES so they map straight onto lvi's :hl overlay (which is byte-indexed).
#
# It always prints EVERY canonical group, emitting a bare `hl GROUP` (no spans)
# for the empty ones. That makes a re-highlight a clean replace of exactly the
# syntax groups, leaving other overlay groups (e.g. `search`) untouched.
#
# Pygments is a natural positional backend: get_tokens_unprocessed tiles the
# input exactly, so walking the tokens in order gives precise offsets -- and a
# multi-line token (an unclosed string, a block comment) is split into one span
# per line automatically, which is exactly what colors the "rest of the file" in
# the unclosed-string case.
#
# THEME MODE (`--theme`): print the `hi GROUP ...` block for a Pygments built-in
# style instead of highlighting stdin, then exit. This seeds the group colors
# you would otherwise hand-write in your rc, so the two surfaces stay in sync.
# The adapter only prints to stdout (positional contract); `lvi-highlight
# --theme` is the piece that runs this and pushes the block over the socket, so
# wire it up once at startup, NOT on every change:
#     on ready LVI_PYGMENTS_STYLE=monokai lvi-highlight --theme
# Because lvi owns the theme, any `hi` you set afterward in the rc still wins;
# the emitted block is just a starting point you can override group by group.
#
# ENVIRONMENT
#   LVI_PYGMENTS_STYLE   Pygments style name for `--theme` (default "default";
#                        try `pygmentize -L styles` for the full list, e.g.
#                        monokai, solarized-dark, gruvbox-dark, nord). Ignored
#                        outside --theme -- highlighting is positional, so the
#                        per-change path never touches colors.
#   LVI_PYGMENTS_DEPTH   Color depth of the `--theme` block: truecolor (default,
#                        exact 24-bit color), 256 (nearest xterm-256 slot -- the
#                        same one `pygmentize -f terminal256` would pick), 16 or
#                        8 (nearest ANSI color, which then follows your terminal
#                        palette). Only affects --theme; the positional path
#                        emits no color at any depth.
import os
import sys
from pygments.lexers import get_lexer_for_filename, guess_lexer_for_filename, get_lexer_by_name
from pygments.util import ClassNotFound
from pygments.token import Token

# Canonical lvi groups, styled in the rc file with :hi. Order here is the
# priority order for mapping a Pygments token type to a group (first match in
# GROUP_MAP wins); GROUPS is the full set we always (re)send.
GROUP_MAP = [
    (Token.Comment.Preproc, "Preproc"),
    (Token.Comment,         "Comment"),
    (Token.String,          "String"),
    (Token.Number,          "Number"),
    (Token.Keyword,         "Keyword"),
    (Token.Operator,        "Operator"),
    (Token.Name.Function,   "Function"),
    (Token.Name.Class,      "Type"),
    (Token.Name.Builtin,    "Builtin"),
    (Token.Name.Constant,   "Constant"),
    (Token.Name.Decorator,  "Preproc"),
    (Token.Name.Tag,        "Keyword"),   # HTML/XML element names
    (Token.Name.Attribute,  "Type"),      # HTML/XML attribute names
    (Token.Name.Namespace,  "Type"),      # module / package names
    (Token.Name.Exception,  "Type"),      # exception class names
    (Token.Name.Label,      "Keyword"),   # goto / loop labels
    (Token.Name.Entity,     "Constant"),  # HTML entities (&amp;, &#160;)
    # Generic.* -- markup/prose/diff tokens the code groups above never cover.
    # Markdown/rST use Heading/Strong/Emph; diff lexers use Inserted/Deleted
    # (and Subheading for hunk headers, folded into Heading here).
    (Token.Generic.Heading,    "Heading"),
    (Token.Generic.Subheading, "Heading"),
    (Token.Generic.Inserted,   "Inserted"),
    (Token.Generic.Deleted,    "Deleted"),
    (Token.Generic.Strong,     "Strong"),
    (Token.Generic.Emph,       "Emph"),
]
GROUPS = ["Comment", "String", "Number", "Keyword", "Operator",
          "Function", "Type", "Builtin", "Constant", "Preproc",
          "Heading", "Inserted", "Deleted", "Strong", "Emph"]


def group_for(ttype):
    for tt, g in GROUP_MAP:
        if ttype in tt:
            return g
    return None


# --theme color depth (LVI_PYGMENTS_DEPTH). lvi's :hi already speaks every one
# of these, so the depth only picks which encoding we emit -- lvi's core needs
# no change. Downscaling a style's hex is a nearest match in RGB: 256 reuses
# Pygments' own table so lvi and a `pygmentize -f terminal256` pager pick the
# SAME slot; 16/8 match nominal ANSI RGB, and the color you actually see then
# follows the terminal's palette (that palette-tracking is the point of asking
# for low color in the first place).
DEPTHS = ("truecolor", "256", "16", "8")

# Nominal xterm RGB for the 16 ANSI colors, in ANSI order (0-15; bright = 8-15).
ANSI16 = [
    (0x00, 0x00, 0x00), (0x80, 0x00, 0x00), (0x00, 0x80, 0x00), (0x80, 0x80, 0x00),
    (0x00, 0x00, 0x80), (0x80, 0x00, 0x80), (0x00, 0x80, 0x80), (0xc0, 0xc0, 0xc0),
    (0x80, 0x80, 0x80), (0xff, 0x00, 0x00), (0x00, 0xff, 0x00), (0xff, 0xff, 0x00),
    (0x00, 0x00, 0xff), (0xff, 0x00, 0xff), (0x00, 0xff, 0xff), (0xff, 0xff, 0xff),
]
# lvi's 8 base color names, in ANSI order 0-7.
ANSI8_NAMES = ["black", "red", "green", "yellow", "blue", "magenta", "cyan", "white"]


def _nearest(rgb, palette):
    r, g, b = rgb
    best, bi = None, 0
    for i, (pr, pg, pb) in enumerate(palette):
        d = (r - pr) ** 2 + (g - pg) ** 2 + (b - pb) ** 2
        if best is None or d < best:
            best, bi = d, i
    return bi


def make_encoder(depth):
    # Return enc(role, hexstr) -> a single `:hi` spec token ("fg=.."/"bg=.."/
    # "sgr=..") for one color at this depth. role is "fg" or "bg".
    closest = None
    if depth == "256":                          # same slot as pygmentize/less
        from pygments.formatters.terminal256 import Terminal256Formatter
        closest = Terminal256Formatter()._closest_color

    def enc(role, hexstr):
        r, g, b = (int(hexstr[i:i + 2], 16) for i in (0, 2, 4))
        if depth == "truecolor":                # exact color, sgr= passthrough
            return "sgr=%s;2;%d;%d;%d" % ("38" if role == "fg" else "48", r, g, b)
        if depth == "256":
            return "%s=%d" % (role, closest(r, g, b))
        if depth == "16":                        # palette index 0-15 (fg=/bg= n)
            return "%s=%d" % (role, _nearest((r, g, b), ANSI16))
        return "%s=%s" % (role, ANSI8_NAMES[_nearest((r, g, b), ANSI16[:8])])
    return enc


def emit_theme():
    # Print a `hi GROUP ...` block derived from a Pygments built-in style, then
    # exit. For each canonical group we style the first token type that maps to
    # it in GROUP_MAP (its representative), turning the style's hex color and
    # attributes into `:hi` specs at LVI_PYGMENTS_DEPTH (truecolor by default).
    # A group the style leaves unstyled emits a bare `hi GROUP` (plain text).
    from pygments.styles import get_style_by_name

    name = os.environ.get("LVI_PYGMENTS_STYLE", "default")
    depth = os.environ.get("LVI_PYGMENTS_DEPTH", "truecolor")
    if depth not in DEPTHS:
        sys.stderr.write("lvi-hl-pygments: bad LVI_PYGMENTS_DEPTH %r (want %s)\n"
                         % (depth, "|".join(DEPTHS)))
        sys.exit(1)
    try:
        style = get_style_by_name(name)
    except ClassNotFound:
        sys.stderr.write("lvi-hl-pygments: unknown style: %s\n" % name)
        sys.exit(1)

    enc = make_encoder(depth)
    rep = {}                        # group -> representative token type
    for tt, g in GROUP_MAP:
        rep.setdefault(g, tt)

    out = []
    for g in GROUPS:
        st = style.style_for_token(rep[g]) if g in rep else {}
        specs = []
        if st.get("color"):
            specs.append(enc("fg", st["color"]))
        if st.get("bgcolor"):
            specs.append(enc("bg", st["bgcolor"]))
        if st.get("bold"):
            specs.append("bold")
        if st.get("italic"):
            specs.append("italic")
        if st.get("underline"):
            specs.append("underline")
        out.append("hi %s %s" % (g, " ".join(specs)) if specs else "hi %s" % g)
    sys.stdout.write("\n".join(out) + "\n")


# Interpreter basename -> Pygments lexer name, for shebangs whose basename
# isn't already a Pygments alias. get_lexer_by_name resolves python/bash/perl/
# ruby/lua/awk/php/... directly; only these need a hand-mapping.
SHEBANG_ALIAS = {"node": "javascript", "nodejs": "javascript",
                 "tclsh": "tcl", "wish": "tcl"}

# Extension-less git message files -> the closest Pygments lexer. There is no
# git-commit lexer, so `diff` is the pragmatic pick: it correctly colors the
# embedded diff of a `git commit -v` buffer and leaves the subject/body/`#`
# comment lines plain, so it never mis-paints the prose message.
FILENAME_MAP = {"COMMIT_EDITMSG": "diff", "MERGE_MSG": "diff",
                "TAG_EDITMSG": "diff"}


def lexer_from_shebang(text):
    # A shebang explicitly declares the interpreter, so mapping it to a lexer is
    # an exact signal -- unlike guess_lexer(text), which never declines and lights
    # prose as code. Parse the interpreter name ourselves rather than trusting
    # guess_lexer's shebang scoring: newer lexers' analyse_text hijack it (a
    # `#!.../python3` file guesses as "Mojo", `node` as "GDScript").
    if not text.startswith("#!"):
        return None
    first = text.split("\n", 1)[0]
    parts = first[2:].split()
    if not parts:
        return None
    interp = os.path.basename(parts[0])
    if interp == "env":             # `env [VAR=val ...] [-opts] INTERP`
        interp = ""
        for p in parts[1:]:
            if "=" in p or p.startswith("-"):
                continue
            interp = os.path.basename(p)
            break
    if not interp:
        return None
    name = SHEBANG_ALIAS.get(interp, interp)
    for cand in (name, name.rstrip("0123456789.")):   # python3.11 -> python
        try:
            return get_lexer_by_name(cand)
        except ClassNotFound:
            pass
    return None


def pick_lexer(text, fname, lang=""):
    if lang:
        try:
            return get_lexer_by_name(lang)
        except ClassNotFound:
            pass                    # unknown name: fall back to filename
    if fname:
        mapped = FILENAME_MAP.get(os.path.basename(fname))
        if mapped:
            try:
                return get_lexer_by_name(mapped)
            except ClassNotFound:
                pass
        try:
            return get_lexer_for_filename(fname)
        except ClassNotFound:
            try:
                return guess_lexer_for_filename(fname, text)
            except ClassNotFound:
                pass
    # A shebang is an explicit interpreter declaration, so an extension-less
    # script (or unnamed buffer) still resolves precisely.
    lx = lexer_from_shebang(text)
    if lx is not None:
        return lx
    # Deliberately NO bare guess_lexer(text) last resort: it never declines --
    # it always returns *some* programming lexer, so a plain-text file with no
    # extension (or an unnamed buffer) gets prose painted as code (ordinary
    # words like "class"/"for"/"return" lit as keywords, numbers as Number).
    # No confident filename/lang/shebang match means no highlighting, same as
    # most editors with an unknown filetype. A .txt resolves to TextLexer above,
    # which tiles as plain Token.Text and so emits no spans anyway.
    return None


def add_span(spans, g, line, c1, c2):
    # Append [line,c1,c2], merging with the previous span of this group when it
    # is contiguous on the same line (so adjacent tokens like a string's open
    # quote + body + close quote collapse to one span).
    lst = spans[g]
    if lst and lst[-1][0] == line and c1 == lst[-1][2] + 1:
        lst[-1][2] = c2
    else:
        lst.append([line, c1, c2])


def main():
    text = sys.stdin.read()
    fname = sys.argv[1] if len(sys.argv) > 1 else ""
    lang = sys.argv[2] if len(sys.argv) > 2 else ""
    spans = {g: [] for g in GROUPS}

    lexer = pick_lexer(text, fname, lang)
    if lexer is not None:
        line, col = 1, 1            # 1-based line and BYTE column
        for _, ttype, value in lexer.get_tokens_unprocessed(text):
            g = group_for(ttype)
            parts = value.split("\n")
            for k, part in enumerate(parts):
                nb = len(part.encode("utf-8"))
                if g is not None and nb > 0:
                    add_span(spans, g, line, col, col + nb - 1)
                if k < len(parts) - 1:  # a newline followed this part
                    line, col = line + 1, 1
                else:
                    col += nb

    out = []
    for g in GROUPS:
        s = spans[g]
        specs = " ".join("%d:%d-%d" % (l, c1, c2) for l, c1, c2 in s)
        out.append(("hl %s %s" % (g, specs)) if s else ("hl %s" % g))
    sys.stdout.write("\n".join(out) + "\n")


def print_help():
    """Print this script's leading comment block (its full reference)."""
    with open(__file__) as f:
        for i, line in enumerate(f):
            if i == 0 and line.startswith("#!"):
                continue
            if not line.startswith("#"):
                break
            sys.stdout.write(line[2:] if line.startswith("# ") else line[1:])


if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        print_help()
    elif len(sys.argv) > 1 and sys.argv[1] == "--theme":
        emit_theme()
    else:
        main()
