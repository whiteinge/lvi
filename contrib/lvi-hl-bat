#!/bin/sh
# lvi-hl-bat -- bat syntax-highlighting adapter for lvi-highlight (ANSI backend).
#
# Contract: buffer text on stdin, filename as $1, optional language name as $2
# (overrides bat's filename detection when set); emits ex commands (produced by
# the shared lvi-hl-ansi parser). Unlike the Pygments (positional) adapter, the
# COLORS come from bat's own theme, not lvi's :hi -- an ANSI backend brings its
# theme and lvi reproduces it. Choose the theme with BAT_THEME; LVI_BAT names
# the binary only (a single word -- flags don't fit through it). No --theme
# mode: `lvi-highlight --theme` needs a positional backend (pygments).
#
# Flags matter for column accuracy: --style=plain (no gutter/grid), --wrap=never
# (don't insert soft newlines) and --tabs=0 (don't expand tabs) keep bat's byte
# columns identical to the buffer's, which is what lvi-hl-ansi relies on.

# -h/--help: print this script's header comment (its full reference), then exit.
case ${1:-} in -h|--help) exec awk 'NR==1&&/^#!/{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0" ;; esac
# Refuse theme mode outright: silently treating --theme as a filename would
# push a block of bare group-clears and read as a mysteriously blank theme.
case ${1:-} in --theme) echo "lvi-hl-bat: no --theme mode (use BAT_THEME; pygments supports --theme)" >&2; exit 1 ;; esac
BAT=${LVI_BAT:-}
if [ -z "$BAT" ]; then
  if   command -v batcat >/dev/null 2>&1; then BAT=batcat   # Debian/Ubuntu name
  elif command -v bat    >/dev/null 2>&1; then BAT=bat
  else echo "lvi-hl-bat: need bat (apt install bat, binary 'batcat')" >&2; exit 1; fi
fi
DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
fname=$1
lang=${2:-}

set -- --color=always --style=plain --paging=never --wrap=never --tabs=0
[ -n "$fname" ] && set -- "$@" --file-name "$fname"     # bat detects syntax from it
[ -n "$lang" ]  && set -- "$@" --language "$lang"       # ...unless a language is forced

"$BAT" "$@" | "$DIR/lvi-hl-ansi"
