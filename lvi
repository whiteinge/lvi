#!/usr/bin/env luajit
--- lvi -- entry point. Dual-role, like tmux:
---   lvi [file]                 launch the editor (optionally on a file)
---   lvi -w <wid> -- <cmds...>  send ex commands to a running view's socket
---   lvi -w auto -- <cmds...>   ... to the sole running view
---   lvi -l                     list running views
--- In client mode it is a Unix filter: ok payloads go to stdout, errors to
--- stderr, and the exit code is non-zero if any command failed.

local script = arg[0]
local dir = script:match("^(.*)/[^/]*$") or "."
package.path = dir .. "/?.lua;" .. dir .. "/vendor/argparse/src/?.lua;" .. package.path

local argparse = require("argparse")

local parser = argparse("lvi", "A minimal vi with a control socket.")
parser:argument("args", "file to edit, or ex commands (after --) in client mode")
      :args("*")
parser:option("-w --wid", "send ex commands to this view's socket ('auto' = sole view)")
parser:flag("-d --detach", "client mode: send without waiting for replies (fire-and-forget)")
parser:flag("-l --list", "list running views and exit")
parser:option("-q --quickfix", "set $LVI_QUICKFIX to FILE and fire the `ready` hook (wire it up in the rc; see lvirc.sample.vim)")
parser:flag("-R --readonly", "open the file(s) read-only: :w fails without ! (POSIX)")

local a = parser:parse()

if a.list then
  local path = require("path")
  for _, v in ipairs(path.list_sockets()) do print(v.wid .. "\t" .. v.path) end
  os.exit(0)
end

if a.wid then
  -- Client mode.
  if #a.args == 0 then io.stderr:write("lvi: no commands given\n"); os.exit(2) end
  local client = require("client")
  local results, err = client.send(a.wid, a.args, a.detach)
  if not results then io.stderr:write("lvi: " .. err .. "\n"); os.exit(1) end
  local rc = 0
  for _, r in ipairs(results) do
    if r.status == "ok" then
      if r.payload ~= "" then io.write(r.payload, "\n") end
    else
      io.stderr:write("lvi: " .. r.cmd .. ": " .. r.payload .. "\n")
      rc = 1
    end
  end
  os.exit(rc)
end

-- Editor mode. Positional args open as buffers (first one current); -q parks an
-- errorfile path in $LVI_QUICKFIX for a `ready` hook (it is not itself a buffer).
--
-- A "-" arg means "read the buffer from standard input" (POSIX vi). Our own
-- stdin is then the pipe, not the keyboard, so we drain it here and reconnect
-- fd 0 to the controlling terminal -- after which the editor's keyboard path
-- (all hardwired to fd 0) works untouched. The drained text seeds the buffer.
-- With no controlling terminal (`printf ... | lvi - >out`) the reopen fails and
-- the editor falls through to headless mode on the drained fd.
local stdin_text
for _, f in ipairs(a.args) do
  if f == "-" then
    local sys = require("sys")
    stdin_text = sys.slurp(0)
    sys.reopen_stdin_from_tty()
    break
  end
end

local editor = require("editor")
local ed = editor.run({ files = a.args, quickfix = a.quickfix, stdin_text = stdin_text,
                        readonly = a.readonly })
os.exit(ed.exit_code or 0)
